">${esc(item.name)}${watchedHtml(item, false)}<\u002Fdiv>\n    <div class=\"item-del\" title=\"Удалить\">✕<\u002Fdiv>`;\n  if (cover) { const img = el.querySelector(\"img\"); img.onload = () => img.classList.add(\"loaded\"); img.onerror = () => { img.remove(); const ph = document.createElement(\"div\"); ph.className = \"ph\"; ph.textContent = item.name; el.prepend(ph); }; img.src = cover; }\n  return el;\n}\nfunction chipEl(item, idx, tierId) {\n  const el = document.createElement(\"div\");\n  el.className = \"chip\";\n  el.dataset.uid = item.uid;\n  el.dataset.tier = tierId;\n  const cover = item.cover || COVERS[item.name] || \"\";\n  el.innerHTML = `<span class=\"chip-rank\">${idx + 1}<\u002Fspan><span class=\"chip-thumb\">${cover ? `<img referrerpolicy=\"no-referrer\" alt=\"\">` : ``}<\u002Fspan>${reactionHtml(item)}<span class=\"cnm\">${esc(item.name)}<\u002Fspan>${watchedHtml(item, true)}<div class=\"item-del\" title=\"Удалить\">✕<\u002Fdiv>`;\n  if (cover) { const img = el.querySelector(\".chip-thumb img\"); if (img) { img.onload = () => img.classList.add(\"loaded\"); img.onerror = () => img.remove(); img.src = cover; } }\n  return el;\n}\nfunction addEl(tierId) {\n  const el = document.createElement(\"div\");\n  el.className = \"additem\";\n  el.dataset.addTier = tierId;\n  el.innerHTML = view === \"grid\"\n    ? `<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><\u002Fsvg><span>добавить<\u002Fspan>`\n    : `<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><\u002Fsvg> добавить`;\n  el.addEventListener(\"click\", () => openModal(null, tierId));\n  return el;\n}\n\n/* ════════════════════ ITEM INTERACTIONS ════════════════════ */\nfunction findItem(uid) {\n  for (const t of state.tiers) { const i = t.items.find(x => x.uid === uid); if (i) return { item: i, tier: t }; }\n  return null;\n}\nfunction bindItems() {\n  document.querySelectorAll(\".card, .chip\").forEach(el => {\n    const uid = +el.dataset.uid;\n    el.draggable = editing;                    /* drag-to-reorder is enabled in edit mode */\n    el.addEventListener(\"mouseenter\", () => showPreview(el, uid));\n    el.addEventListener(\"mouseleave\", hidePreview);\n    el.addEventListener(\"click\", e => {\n      if (e.target.closest(\".item-del\")) return;\n      if (editing) openModal(uid);\n    });\n    const del = el.querySelector(\".item-del\");\n    if (del) del.addEventListener(\"click\", e => { e.stopPropagation(); removeItem(uid); });\n  });\n}\n\n/* ════════════════════ DRAG-AND-DROP REORDER (edit mode) ════════════════════ */\nlet dragUid = null;\n/* move an item to a tier, inserting it before `beforeUid` (or appending if null) */\nfunction moveItem(uid, toTierId, beforeUid) {\n  const f = findItem(uid); if (!f || uid === beforeUid) return;\n  const item = f.item;\n  f.tier.items = f.tier.items.filter(x => x.uid !== uid);\n  const dest = state.tiers.find(t => t.id === toTierId) || f.tier;\n  let idx = dest.items.length;\n  if (beforeUid != null) { const i = dest.items.findIndex(x => x.uid === beforeUid); if (i >= 0) idx = i; }\n  dest.items.splice(idx, 0, item);\n  save(); render();\n}\nfunction setDraggable(on) { document.querySelectorAll(\".card, .chip\").forEach(el => el.draggable = on); }\nfunction clearDropMarks() {\n  document.querySelectorAll(\".drop-before, .drop-after\").forEach(el => el.classList.remove(\"drop-before\", \"drop-after\"));\n  document.querySelectorAll(\".tier.drag-over\").forEach(el => el.classList.remove(\"drag-over\"));\n}\n/* resolve { tier, beforeUid } from a drag event over the board */\nfunction dropTarget(e) {\n  const tierEl = e.target.closest(\".tier\");\n  const toTier = tierEl ? tierEl.dataset.tier : null;\n  let beforeUid = null;\n  const over = e.target.closest(\".card, .chip\");\n  if (over && +over.dataset.uid !== dragUid) {\n    const r = over.getBoundingClientRect();\n    const after = e.clientX > r.left + r.width / 2;\n    if (after) {\n      let n = over.nextElementSibling;\n      while (n && !n.matches(\".card, .chip\")) n = n.nextElementSibling;\n      beforeUid = n ? +n.dataset.uid : null;\n    } else { beforeUid = +over.dataset.uid; }\n  }\n  return { toTier, beforeUid, over, tierEl };\n}\nboard.addEventListener(\"dragstart\", e => {\n  const it = e.target.closest(\".card, .chip\");\n  if (!it || !editing) return;\n  dragUid = +it.dataset.uid;\n  it.classList.add(\"dragging\");\n  hidePreview();\n  e.dataTransfer.effectAllowed = \"move\";\n  try { e.dataTransfer.setData(\"text/plain\", String(dragUid)); } catch (_) {}\n});\nboard.addEventListener(\"dragend\", () => { document.querySelectorAll(\".dragging\").forEach(el => el.classList.remove(\"dragging\")); clearDropMarks(); dragUid = null; });\nboard.addEventListener(\"dragover\", e => {\n  if (dragUid == null) return;\n  e.preventDefault();\n  e.dataTransfer.dropEffect = \"move\";\n  clearDropMarks();\n  const { over, tierEl } = dropTarget(e);\n  if (tierEl) tierEl.classList.add(\"drag-over\");\n  if (over && +over.dataset.uid !== dragUid) {\n    const r = over.getBoundingClientRect();\n    over.classList.add(e.clientX > r.left + r.width / 2 ? \"drop-after\" : \"drop-before\");\n  }\n});\nboard.addEventListener(\"drop\", e => {\n  if (dragUid == null) return;\n  e.preventDefault();\n  const { toTier, beforeUid } = dropTarget(e);\n  const u = dragUid; dragUid = null; clearDropMarks();\n  if (toTier) { moveItem(u, toTier, beforeUid); toast(\"Перемещено\"); }\n});\nfunction removeItem(uid) {\n  const f = findItem(uid); if (!f) return;\n  pendingDel = uid;\n  document.getElementById(\"cName\").textContent = f.item.name;\n  confirmOverlay.classList.add(\"show\");\n  setTimeout(() => cCancel.focus(), 60);\n}\nfunction closeConfirm() { confirmOverlay.classList.remove(\"s