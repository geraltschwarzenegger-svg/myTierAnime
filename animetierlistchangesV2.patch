.co/file/anilistcdn/media/anime/cover/large/bx20872-j5PBzzVtrYDM.jpg\",\n  \"Шарлотта\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20997-axVYrsIfjtYJ.jpg\",\n  \"Ангел кровопролития\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx99629-BXyAJ6PDq4sr.jpg\",\n  \"Я получил читерские способности\": \"https://media.kitsu.app/anime/46370/poster_image/large-338a164d72dacaa07fc4b6ea58fa1efc.jpeg\",\n  \"Нина в королевстве звёзд\": \"https://media.kitsu.app/anime/48391/poster_image/large-da08a161da14064a4f1e18ee46d268a7.jpeg\",\n  \"Одинокий рокер!\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx130003-HTDmeL4RGeJ4.png\",\n  \"Чёрный призыватель\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx145260-Yt5W8aQQKqF2.jpg\",\n  \"Сага о винланде\": \"https://media.kitsu.app/anime/poster_images/41084/large.jpg\",\n  \"Рандеву с жизнью\": \"https://media.kitsu.app/anime/poster_images/7421/large.jpg\",\n  \"Форма голоса\": \"https://media.kitsu.app/anime/poster_images/10028/large.jpg\",\n  \"Тоннель в лето\": \"https://media.kitsu.app/anime/45598/poster_image/large-757f81fe372ae4a0b63fc8897416a562.jpeg\",\n  \"Голубая шкатулка\": \"https://media.kitsu.app/anime/48239/poster_image/large-b547e3cfeb2776aa95f8618d0a6ff0fe.jpeg\",\n  \"Красноволосая принцесса\": \"https://media.kitsu.app/anime/poster_images/10621/large.jpg\",\n  \"Фарфоровая кукла влюбилась\": \"https://media.kitsu.app/anime/44382/poster_image/large-8ffc8ea9b6a1f9e79bc626e03baab167.jpeg\",\n  \"Укрась прощальное утро цветами\": \"https://media.kitsu.app/anime/poster_images/13955/large.jpg\",\n  \"Иная\": \"https://media.kitsu.app/anime/poster_images/6356/large.jpg\",\n  \"Механическая Мари\": \"https://media.kitsu.app/manga/poster_images/45749/large.jpg\",\n  \"Мой статус убийцы очевидно превосходит геройский\": \"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx103655-v8Inz6BscNSW.png\",\n  \"Врата: Там бьются наши воины\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20994-pSDk4I58jAK5.jpg\",\n  \"В лесу где мерцают светлячки\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx10408-PlKJ6DAyvMk2.png\",\n  \"5 сантиметра в секунду 2007\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx1689-rJKhjLEjQHSy.jpg\",\n  \"Сад изящных слов\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx16782-qpFGk18UqaHn.jpg\",\n  \"Я, владыка демонов, взял эльфийку-рабыню в жёны. И как же мне её любить?\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx156023-cY4NC8gCcAg7.jpg\",\n  \"Арифурэта\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx100668-DvOn5bMOt4cy.jpg\",\n  \"Школа мертвецов\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx8074-YB63Ik96fjPj.png\",\n  \"Ненасытный берсерк\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx156039-JnepQcVxXLLW.jpg\",\n  \"Берсерк\": \"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx33-PSwfE5B0gejI.jpg\"\n};\n\n/* ════════════════════ DEFAULT DATA ════════════════════ */\nconst FAVS = new Set([\"Violet Evergarden\",\"Любимый во Франксе\",\"Восхождение в тени\",\"Атака Титанов\"]);\nconst TIER_META = {\n  S: { label: \"Шедевры\",        tagline: \"Истории, которые выходят за пределы жанра, меняют внутренний взгляд на человека и мир и продолжают жить в памяти после финальных титров.\" },\n  A: { label: \"Близко к идеалу\", tagline: \"Произведения редкой цельности, в которых замысел, эмоция и форма почти достигают совершенного равновесия.\" },\n  B: { label: \"Крепкая основа\",  tagline: \"Истории с собственным голосом и настоящей силой, способные увлечь, растрогать, удивить или заставить задуматься, даже если им недостаёт безупречности.\" },\n  C: { label: \"Достойные\",       tagline: \"Произведения не без слабостей, но с ярким образом, искренним чувством или ценной мыслью, благодаря которым знакомство с ними было не напрасным.\" }\n};\nconst RAW = {\n  S: [\"Violet Evergarden\",\"Атака Титанов\",\"Класс превосходства\",\"Человек-бензопила\",\"Любимый во Франксе\",\"Адский рай\",\"86\",\"Восхождение в тени\",\"Поднятие уровня в соло\",\"Фрирен\",\"Школа мертвецов\"],\n  A: [\"Благоухающий цветок расцветает с достоинством\",\"Твоё имя\",\"Песнь ночных сов\",\"Аля кокетничает по-русски\",\"Город, в котором меня нет\",\"Невеста чародея\",\"Врата Штейна\",\"Мастера на все руки выгнали из отряда героев\",\"Последний Серафим\",\"Сто девушек, которые очень любят\",\"Я, владыка демонов, взял эльфийку-рабыню в жёны. И как же мне её любить?\",\"Сад изящных слов\",\"Ненасытный берсерк\",\"Берсерк\",\"Магическая битва\"],\n  B: [\"Ангел по соседству\",\"Моя девушка не только милая\",\"Опытная тебя и неопытного меня\",\"Твоя апрельская ложь\",\"Пластиковые воспоминания\",\"Шарлотта\",\"Ангел кровопролития\",\"Я получил читерские способности\",\"Нина в королевстве звёзд\",\"Одинокий рокер!\",\"Чёрный призыватель\",\"Сага о винланде\",\"Рандеву с жизнью\",\"Арифурэта\"],\n  C: [\"Форма голоса\",\"Тоннель в лето\",\"Голубая шкатулка\",\"Красноволосая принцесса\",\"Фарфоровая кукла влюбилась\",\"5 сантиметра в секунду 2007\",\"Re:ZERO\",\"Укрась прощальное утро цветами\",\"Врата: Там бьются наши воины\",\"В лесу где мерцают светлячки\",\"Иная\",\"Механическая Мари\",\"Мой статус убийцы очевидно превосходит геройский\",\"На твоей волне\"]\n};\nfunction defaultState() {\n  let uid = 1;\n  const tiers = [\"S\",\"A\",\"B\",\"C\"].map(id => ({\n    id, ...TIER_META[id],\n    items: RAW[id].map(name => {\n      const fav = FAVS.has(name);\n      return { uid: uid++, name, cover: COVERS[name] || \"\", fav, reaction: fav ? (id === \"S\" ? \"goldheart\" : \"heart\") : null };\n    })\n  }));\n  return { tiers, nextUid: uid };\n}\n\n/* ════════════════════ STATE & PERSISTENCE ════════════════════ */\nconst LS_KEY = \"anime-tierlist-v2\";\nlet state, view = \"grid\", editing = false;\n\nfunction migrateAndBackfillState(loadedState) {\n  const currentNames = new Set();\n  loadedState.tiers.forEach((t) => {\n    // refresh tier copy — labels/taglines may have changed between app versions\n    if (TIER_META[t.id]) { t.label = TIER_META[t.id].label; t.tagline = TIER_META[t.id].tagline; }\n    t.items.forEach((item) => {\n      currentNames.add(item.name);\n      // Backfill or update cover if empty or outdated (not matching COVERS fallbacks, or contains shikimori link, or old Violet Evergarden TV cover)\n      if ((!item.cover || item.cover === \"\" || item.cover.includes(\"shikimori\") || (item.name === \"Violet Evergarden\" && item.cover.includes(\"bx21827\"))) && COVERS[item.name]) {\n        item.cover = COVERS[item.name];\n      }\n      if (item.watched !== undefined) item.watched = normWatched(item.watched);\n      // migrate legacy boolean favourite → reaction marker (S favourites become gold)\n      if (item.reaction === undefined) item.reaction = item.fav ? (t.id === \"S\" ? \"goldheart\" : \"heart\") : null;\n    });\n  });\n\n  let uid = loadedState.nextUid || 1000;\n\n  const newItems = [\n    { name: \"Школа мертвецов\", tierId: \"S\" },\n    { name: \"Ненасытный берсерк\", tierId: \"A\" },\n    { name: \"Берсерк\", tierId: \"A\" },\n    { name: \"Арифурэта\", tierId: \"B\" },\n    { name: \"Магическая битва\", tierId: \"A\" },\n    { name: \"На твоей волне\", tierId: \"C\" }\n  ];\n\n  let stateUpdated = false;\n  loadedState.tiers.forEach((t) => {\n    const toAdd = newItems.filter((x) => x.tierId === t.id && !currentNames.has(x.name));\n    if (toAdd.length > 0) {\n      stateUpdated = true;\n      toAdd.forEach((item) => {\n        t.items.push({\n          uid: uid++,\n          name: item.name,\n          cover: COVERS[item.name] || \"\",\n          fav: false,\n          reaction: null\n        });\n      });\n    }\n  });\n\n  if (stateUpdated) {\n    loadedState.nextUid = uid;\n  }\n  return loadedState;\n}\n\nfunction load() {\n  try {\n    const raw = localStorage.getItem(LS_KEY);\n    if (raw) {\n      const p = JSON.parse(raw);\n      if (p && p.tiers) {\n        return migrateAndBackfillState(p);\n      }\n    }\n  } catch(e) {}\n  return defaultState();\n}\nfunction save() {\n  try { localStorage.setItem(LS_KEY, JSON.stringify(state)); } catch(e) {}\n}\nfunction loadView() { try { const v = localStorage.getItem(LS_KEY + \":view\"); if (v) view = v; } catch(e){} }\nfunction saveView() { try { localStorage.setItem(LS_KEY + \":view\", view); } catch(e){} }\n\nstate = load();\nloadView();\n\n/* ════════════════════ RENDER ════════════════════ */\nconst board = document.getElementById(\"board\");\nlet firstRender = true;\nconst esc = s => String(s).replace(/[&<>\"]/g, c => ({\"&\":\"&amp;\",\"<\":\"&lt;\",\">\":\"&gt;\",'\"':\"&quot;\"}[c]));\n\n/* watched-date helpers (supports legacy string + new list form) */\nfunction normWatched(w) {\n  if (!w) return [];\n  if (typeof w === \"string\") return w.trim() ? [{ label: \"\", date: w.trim() }] : [];\n  if (Array.isArray(w)) return w.filter(e => e && e.date);\n  return [];\n}\nfunction parseRuDate(d) {\n  const m = /^(\\d{1,2})\\.(\\d{1,2})\\.(\\d{4})$/.exec((d || \"\").trim());\n  return m ? new Date(+m[3], +m[2] - 1, +m[1]).getTime() : 0;\n}\nfunction watchedLatest(a) {\n  let best = a[0], bt = -1;\n  a.forEach(e => { const t = parseRuDate(e.date); if (t >= bt) { bt = t; best = e; } });\n  return best;\n}\nfunction watchedHtml(item, chip) {\n  const a = normWatched(item.watched);\n  if (!a.length) return \"\";\n  const pre = chip ? \"\" : \"▸ \";\n  if (a.length === 1) return `<span class=\"watched\">${pre}${esc(a[0].date)} г.<\u002Fspan>`;\n  const last = watchedLatest(a);\n  return `<span class=\"watched\">${pre}${esc(last.date)} г.<i>+${a.length - 1}<\u002Fi><\u002Fspan>`;\n}\n\n/* ════════════════════ REACTIONS (animated favourite markers) ════════════════════ */\nconst RX_ICONS = {\n  heart:     '<path d=\"M12 21s-7.5-4.7-10-9.2C.5 8.4 2 4.5 5.7 4.5c2 0 3.4 1.2 4.3 2.4.9-1.2 2.3-2.4 4.3-2.4 3.7 0 5.2 3.9 3.7 7.3C19.5 16.3 12 21 12 21z\"/>',\n  bolt:      '<path d=\"M13 2 4 14h6l-1 8 9-13h-6l1-7z\"/>',\n  fire:      '<path d=\"M12 2c2 3 .6 5 .6 7 .8-.4 1.5-1.2 1.8-2.3 1.6 1.6 2.8 3.8 2.8 6.1A7.2 7.2 0 0 1 5 13.6C5 9 9 7 12 2z\"/>',\n  star:      '<path d=\"M12 2l2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.8 5.9 20.6l1.4-6.8L2.2 9.1l6.9-.8z\"/>'\n};\nconst REACTIONS = {\n  heart:     { label: \"Сердце\",         ic: RX_ICONS.heart },\n  goldheart: { label: \"Золотое сердце\",  ic: RX_ICONS.heart },\n  bolt:      { label: \"Молния\",          ic: RX_ICONS.bolt },\n  fire:      { label: \"Огонь\",           ic: RX_ICONS.fire },\n  star:      { label: \"Звезда\",          ic: RX_ICONS.star }\n};\nconst RX_ORDER = [\"heart\", \"goldheart\", \"bolt\", \"fire\", \"star\"];\n/* resolve an item's reaction key, tolerating the legacy boolean `fav` flag */\nfunction reactionKey(item) {\n  if (item && item.reaction && REACTIONS[item.reaction]) return item.reaction;\n  if (item && item.fav && !item.reaction) return \"heart\";\n  return null;\n}\nfunction reactionHtml(item) {\n  const k = reactionKey(item);\n  if (!k) return \"\";\n  return `<span class=\"rx rx-${k}\" aria-label=\"${REACTIONS[k].label}\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">${REACTIONS[k].ic}<\u002Fsvg><\u002Fspan>`;\n}\n\n/* animate a number counting up to its target (eased, reduced-motion aware) */\nfunction animateCount(el, target, dur = 900) {\n  if (!el) return;\n  const start = parseInt(el.textContent, 10) || 0;\n  if (start === target || matchMedia(\"(prefers-reduced-motion: reduce)\").matches) { el.textContent = target; return; }\n  const t0 = performance.now();\n  (function step(now) {\n    const p = Math.min(1, (now - t0) / dur);\n    const e = 1 - Math.pow(1 - p, 3); /* easeOutCubic */\n    el.textContent = Math.round(start + (target - start) * e);\n    if (p < 1) requestAnimationFrame(step);\n  })(performance.now());\n}\n\n/* count of titles whose latest watch date falls in the current year */\nfunction countWatchedThisYear() {\n  const yr = new Date().getFullYear();\n  let n = 0;\n  state.tiers.forEach(t => t.items.forEach(i => {\n    if (normWatched(i.watched).some(e => { const ms = parseRuDate(e.date); return ms && new Date(ms).getFullYear() === yr; })) n++;\n  }));\n  return n;\n}\n\nfunction render() {\n  board.innerHTML = \"\";\n  let total = 0, fav = 0;\n  state.tiers.forEach(tier => {\n    total += tier.items.length;\n    fav += tier.items.filter(i => reactionKey(i)).length;\n    const art = document.createElement(\"article\");\n    art.className = \"tier\";\n    art.dataset.tier = tier.id;\n    art.innerHTML = `\n      <div class=\"badge\">\n        <span class=\"brun\"><\u002Fspan>\n        <span class=\"crown\" aria-hidden=\"true\"><svg viewBox=\"0 0 34 24\"><path d=\"M3 21 L4.6 8.5 L10.6 13.8 L17 4.5 L23.4 13.8 L29.4 8.5 L31 21 Z\" fill=\"currentColor\"><\u002Fpath><rect x=\"4\" y=\"20\" width=\"26\" height=\"3.2\" rx=\"1\" fill=\"currentColor\"><\u002Frect><circle cx=\"17\" cy=\"9\" r=\"1.5\" fill=\"#fff3cf\"><\u002Fcircle><circle cx=\"6.4\" cy=\"11.4\" r=\"1.2\" fill=\"#fff3cf\"><\u002Fcircle><circle cx=\"27.6\" cy=\"11.4\" r=\"1.2\" fill=\"#fff3cf\"><\u002Fcircle><\u002Fsvg><\u002Fspan>\n        <span class=\"letter\" data-l=\"${tier.id}\">${tier.id}<\u002Fspan>\n        <span class=\"cnt\"><b>${tier.items.length}<\u002Fb> тайтлов<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"panel\">\n        <div class=\"panel-head\">\n          <span class=\"label\">${esc(tier.label)}<\u002Fspan>\n          <span class=\"tagline\">${esc(tier.tagline)}<\u002Fspan>\n          <span class=\"pillct\">${tier.id} · ${tier.items.length}<\u002Fspan>\n        <\u002Fdiv>\n        <div class=\"items ${view}\"><\u002Fdiv>\n      <\u002Fdiv>`;\n    const wrap = art.querySelector(\".items\");\n    tier.items.forEach((item, idx) => wrap.appendChild(view === \"grid\" ? card