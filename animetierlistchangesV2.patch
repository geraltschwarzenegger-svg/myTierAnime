 .chip:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--t) 60%, transparent); box-shadow: 0 8px 22px -8px var(--tg); background: linear-gradient(160deg, rgba(255,255,255,.12), rgba(255,255,255,.03)); }\n\n  @keyframes beat { 0%,60%,100%{transform:scale(1)} 20%{transform:scale(1.25)} 40%{transform:scale(1.1)} }\n  /* newly added card/chip springs in (FLIP reflow handles the others) */\n  .just-in { animation: cardIn .5s cubic-bezier(.2,.85,.25,1) both; }\n  @keyframes cardIn { 0% { opacity: 0; transform: scale(.7) translateY(10px); } 60% { opacity: 1; } 100% { opacity: 1; transform: none; } }\n  .dim { opacity: .22; filter: grayscale(.55); transition: opacity .25s ease, filter .25s ease; }\n\n  /* edit affordances */\n  .item-del {\n    position: absolute; z-index: 5; width: 22px; height: 22px; border-radius: 50%;\n    display: none; place-items: center; cursor: pointer; border: 1px solid rgba(255,255,255,.25);\n    background: rgba(20,8,16,.85); color: #ff8aa8; font-size: 13px; line-height: 1;\n    transition: transform .15s, background .15s, color .15s;\n  }\n  .card .item-del { top: 6px; right: 6px; }\n  .chip .item-del { position: static; display: none; width: 18px; height: 18px; margin-left: 2px; margin-right: -4px; }\n  body.editing .item-del { display: grid; }\n  .item-del:hover { background: #ff5c95; color: #fff; transform: scale(1.12); }\n  body.editing .card { cursor: grab; touch-action: none; }\n  body.editing .chip { cursor: grab; touch-action: none; }\n  body.editing .card:hover { transform: translateY(-3px); }\n  /* floating clone that follows the finger during a touch drag */\n  .drag-ghost { position: fixed; left: 0; top: 0; z-index: 250; pointer-events: none; opacity: .92;\n    transition: none !important; animation: none !important; transform-origin: top left;\n    border-radius: 15px; box-shadow: 0 26px 54px -12px rgba(0,0,0,.72), 0 0 30px -6px rgba(120,160,255,.4); }\n  .drag-ghost::before, .drag-ghost::after { display: 