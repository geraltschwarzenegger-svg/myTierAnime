68 760,704 T1200,710 L1200,800 L0,800 Z\" fill=\"#08060f\"><\u002Fpath>\n    <\u002Fsvg>\n  <\u002Fdiv>\n  <div class=\"grid-layer\"><\u002Fdiv>\n  <div class=\"shard s1\"><\u002Fdiv>\n  <div class=\"shard s2\"><\u002Fdiv>\n  <canvas id=\"fx\"><\u002Fcanvas>\n  <div class=\"center-calm\"><\u002Fdiv>\n  <div class=\"bg-tint\"><\u002Fdiv>\n<\u002Fdiv>\n<div class=\"grain\" aria-hidden=\"true\"><\u002Fdiv>\n<div class=\"vignette\" aria-hidden=\"true\"><\u002Fdiv>\n<div class=\"rain-glass\" aria-hidden=\"true\"><span class=\"drip\"><\u002Fspan><span class=\"drip\"><\u002Fspan><span class=\"drip\"><\u002Fspan><span class=\"drip\"><\u002Fspan><span class=\"drip\"><\u002Fspan><\u002Fdiv>\n<div id=\"cursorGlow\" aria-hidden=\"true\"><\u002Fdiv>\n<div id=\"wings\" aria-hidden=\"true\">\n  <span class=\"wing wing-l\"><svg viewBox=\"0 0 130 120\" fill=\"currentColor\"><path d=\"M2 78 C 30 70, 52 64, 70 40 C 72 58, 68 70, 60 80 C 78 72, 92 60, 100 44 C 102 60, 98 72, 90 82 C 104 76, 116 66, 124 52 C 128 70, 120 86, 104 96 C 84 108, 44 104, 2 78 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan>\n  <span class=\"wing wing-r\"><svg viewBox=\"0 0 130 120\" fill=\"currentColor\"><path d=\"M2 78 C 30 70, 52 64, 70 40 C 72 58, 68 70, 60 80 C 78 72, 92 60, 100 44 C 102 60, 98 72, 90 82 C 104 76, 116 66, 124 52 C 128 70, 120 86, 104 96 C 84 108, 44 104, 2 78 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan>\n<\u002Fdiv>\n\n<button id=\"fxGear\" class=\"fx-gear\" title=\"Эффекты\" aria-label=\"Настройки эффектов\">\n  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><circle cx=\"12\" cy=\"12\" r=\"3.2\"><\u002Fcircle><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2