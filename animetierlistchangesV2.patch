b.dataset.t)));\n\n/* reaction picker (modal) */\nconst fReaction = document.getElementById(\"fReaction\");\nlet pickReaction = null;\nfunction setReaction(k) {\n  pickReaction = (k && REACTIONS[k]) ? k : null;\n  fReaction.querySelectorAll(\"button\").forEach(b => b.classList.toggle(\"sel\", (b.dataset.rx || \"\") === (pickReaction || \"\")));\n}\nfReaction.querySelectorAll(\"button\").forEach(b => b.addEventListener(\"click\", () => setReaction(b.dataset.rx)));\n\n/* representative hue per tier — feeds the particle burst with on-brand colour */\nconst TIER_HUE = { S: 45, A: 173, B: 266, C: 150 };\n/* fire a celebratory neon burst from the centre of a tier's badge */\nfunction celebrate(tierId) {\n  if (typeof window.__fxBurst !== \"function\") return;\n  const badge = document.querySelector(`.tier[data-tier=\"${tierId}\"] .badge`);\n  if (!badge) return;\n  const r = badge.getBoundingClientRect();\n  window.__fxBurst(r.left + r.width / 2, r.top + r.height / 2, TIER_HUE[tierId]);\n}\n\nfunction openModal(uid, presetTier) {\n  editUid = uid || null;\n  if (uid) {\n    const f = findItem(uid); if (!f) return;\n    document.getElementById(\"mTitle\").textContent = \"Редактировать тайтл\";\n    document.getElementById(\"mSub\").textContent = \"Измени название, обложку или тир\";\n    fName.value = f.item.name; fCover.value = f.item.cover || \"\"; setReaction(reactionKey(f.item));\n    fWatchedList.innerHTML = \"\"; const _wl = normWatched(f.item.watched); (_wl.length ? _wl : [{ label: \"\", date: \"\" }]).forEach(e => fWatchedList.appendChild(watchRow(e.label, e.date)));\n    setPick(f.tier.id);\n    document.getElementById(\"mSave\").textContent = \"Сохранить\";\n  } else {\n    document.getElementById(\"mTitle\").textContent = \"Добавить тайтл\";\n    document.getElementById(\"mSub\").textContent = \"Заполни название и выбери тир\";\n    fName.value = \"\"; fCover.value = \"\"; setReaction(null);\n    fWatchedList.innerHTML = \"\"; fWatchedList.appendChild(watchRow(\"\", \"\"));\n    setPick(presetTier || \"S\");\n    document.getElementById(\"mSave\").textContent = \"Добавить\";\n  }\n  overlay.classList.add(\"show\");\n  setTimeout(() => fName.focus(), 60);\n}\nfunction closeModal() { overlay.classList.remove(\"show\"); editUid = null; }\n\ndocument.getElementById(\"mCancel\").addEventListener(\"click\", closeModal);\noverlay.addEventListener(\"click\", e => { if (e.target === overlay) closeModal(); });\ndocument.addEventListener(\"keydown\", e => {\n  if (e.key === \"Escape\") {\n    if (statsOverlay.classList.contains(\"show\")) { closeStats(); return; }\n    if (confirmOverlay.classList.contains(\"show\")) { closeConfirm(); return; }\n    if (overlay.classList.contains(\"show\")) closeModal();\n  }\n});\n\ndocument.getElementById(\"mSave\").addEventListener(\"click\", () => {\n  const name = fName.value.trim();\n  if (!name) { fName.focus(); fName.style.borderColor = \"var(--s)\"; return; }\n  const cover = fCover.value.trim();\n  const reaction = pickReaction;\n  const watched = [...fWatchedList.querySelectorAll(\".wrow\")].map(r => ({ label: r.querySelector(\".wlabel\").value.trim(), date: r.querySelector(\".wdate\").value.trim() })).filter(e => e.date);\n  if (editUid) {\n    const f = findItem(editUid);\n    if (f) {\n      f.item.name = name; f.item.cover = cover; f.item.reaction = reaction; f.item.fav = !!reaction; f.item.watched = watched;\n      if (f.tier.id !== pickTier) {\n        f.tier.items = f.tier.items.filter(x => x.uid !== editUid);\n        state.tiers.find(t => t.id === pickTier).items.push(f.item);\n      }\n    }\n    toast(\"Изменено\");\n  } else {\n    const item = { uid: state.nextUid++, name, cover: cover || COVERS[name] || \"\", fav: !!reaction, reaction, watched };\n    state.tiers.find(t => t.id === pickTier).items.push(item);\n    toast(\"Добавлено в \" + pickTier);\n  }\n  save(); flipRerender(); celebrate(pickTier); closeModal();\n});\nfName.addEventListener(\"keydown\", e => { if (e.key === \"Enter\") document.getElementById(\"mSave\").click(); });\n\n/* ════════════════════ TOOLBAR ════════════════════ */\nfunction setView(v) {\n  if (v !== \"grid\" && v !== \"chips\") return;\n  document.querySelectorAll(\"#viewSeg button\").forEach(x => x.classList.toggle(\"on\", x.dataset.view === v));\n  if (v === view) return;          /* already active — just sync the segmented control */\n  view = v; saveView(); render();\n}\ndocument.getElementById(\"viewSeg\").addEventListener(\"click\", e => {\n  const b = e.target.closest(\"button\"); if (b) setView(b.dataset.view);\n});\n// set initial seg state\ndocument.querySelectorAll(\"#viewSeg button\").forEach(x => x.classList.toggle(\"on\", x.dataset.view === view));\n\n/* live search / filter — search dims non-matches; «только любимые» hides the rest */\nlet searchQ = \"\", favOnly = false;\nconst searchInput = document.getElementById(\"searchInput\");\nfunction applySearch() {\n  const q = searchQ;\n  document.querySelectorAll(\".tier\").forEach(t => {\n    let anyVisible = false;\n    t.querySelectorAll(\".card, .chip\").forEach(el => {\n      const f = findItem(+el.dataset.uid);\n      const isFav = f && reactionKey(f.item);\n      const hidden = favOnly && !isFav;\n      el.style.display = hidden ? \"none\" : \"\";\n      const match = !q || (f && f.item.name.toLowerCase().includes(q));\n      el.classList.toggle(\"dim\", !hidden && !!q && !match);\n      if (!hidden && match) anyVisible = true;\n    });\n    t.querySelectorAll(\".additem\").forEach(a => a.style.display = (q || favOnly) ? \"none\" : \"\");\n    t.style.display = ((q || favOnly) && !anyVisible) ? \"none\" : \"\";\n  });\n}\nsearchInput.addEventListener(\"input\", () => { searchQ = searchInput.value.trim().toLowerCase(); applySearch(); });\n\nconst favBtn = document.getElementById(\"favBtn\");\nfavBtn.addEventListener(\"click\", () => {\n  favOnly = !favOnly;\n  favBtn.classList.toggle(\"on\", favOnly);\n  applySearch();\n  toast(favOnly ? \"Только любимые ♥\" : \"Показаны все\");\n});\n\n/* ════════════════════ TASTE STATISTICS (bento) ════════════════════ */\nconst statsOverlay = document.getElementById(\"statsOverlay\");\n/* a playful verdict derived from how the collection is shaped */\nfunction tasteVerdict(counts, total, favs) {\n  if (!total) return [\"🎬\", \"Чистый лист\", \"Добавь первые тайтлы — и здесь оживёт карта твоего вкуса.\"];\n  const sShare = counts.S / total, favShare = favs / total;\n  const maxId = [\"S\", \"A\", \"B\", \"C\"].reduce((a, b) => counts[b] > counts[a] ? b : a, \"S\");\n  if (sShare >= 0.4) return [\"🏆\", \"Сенсей старой школы\", \"Почти всё для тебя — шедевр. Высочайшая планка вкуса.\"];\n  if (favShare >= 0.33) return [\"💞\", \"Романтик эпохи Рэйва\", \"Ты смотришь сердцем — отмеченных любимыми очень много.\"];\n  if (maxId === \"C\") return [\"🧭\", \"Любопытный исследователь\", \"Ты ценишь сам путь и пробуешь разное, не гонясь за идеалом.\"];\n  if (maxId === \"S\" || maxId === \"A\") return [\"⚖️\", \"Взыскательный критик\", \"Крепкая иерархия и ясные предпочтения — ты знаешь, чего хочешь.\"];\n  return [\"🌸\", \"Дзен-куратор\", \"Спокойная, со вкусом собранная коллекция без перекосов.\"];\n}\nfunction openStats() {\n  let total = 0, favs = 0; const counts = { S: 0, A: 0, B: 0, C: 0 };\n  state.tiers.forEach(t => { counts[t.id] = t.items.length; total += t.items.length; t.items.forEach(i => { if (reactionKey(i)) favs++; }); });\n  const colors = { S: \"var(--gold)\", A: \"var(--a)\", B: \"var(--b)\", C: \"var(--c)\" };\n  let acc = 0; const segs = [];\n  [\"S\", \"A\", \"B\", \"C\"].forEach(id => {\n    const frac = total ? counts[id] / total : 0;\n    if (frac > 0) segs.push(`${colors[id]} ${(acc * 360).toFixed(2)}deg ${((acc + frac) * 360).toFixed(2)}deg`);\n    acc += frac;\n  });\n  const donut = document.getElementById(\"stDonut\");\n  donut.style.background = segs.length ? `conic-gradient(${segs.join(\",\")})` : \"rgba(255,255,255,.08)\";\n  donut.innerHTML = `<div class=\"donut-hole\"><b>${total}<\u002Fb><span>всего<\u002Fspan><\u002Fdiv>`;\n  document.getElementById(\"stLegend\").innerHTML = [\"S\", \"A\", \"B\", \"C\"].map(id =>\n    `<span class=\"lg\"><i style=\"background:${colors[id]}\"><\u002Fi>${id} · ${counts[id]} (${total ? Math.round(counts[id] / total * 100) : 0}%)<\u002Fspan>`).join(\"\");\n  document.getElementById(\"stbTotal\").textContent = total;\n  document.getElementById(\"stbFav\").textContent = favs;\n  document.getElementById(\"stbTop\").textContent = total ? [\"S\", \"A\", \"B\", \"C\"].reduce((a, b) => counts[b] > counts[a] ? b : a, \"S\") : \"—\";\n  document.getElementById(\"stbYear\").textContent = countWatchedThisYear();\n  const [emoji, title, desc] = tasteVerdict(counts, total, favs);\n  document.getElementById(\"stEmoji\").textContent = emoji;\n  document.getElementById(\"stVerdict\").textContent = title;\n  document.getElementById(\"stVerdictDesc\").textContent = desc;\n  statsOverlay.classList.add(\"show\");\n}\nfunction closeStats() { statsOverlay.classList.remove(\"show\"); }\ndocument.getElementById(\"statsBtn\").addEventListener(\"click\", openStats);\ndocument.getElementById(\"stClose\").addEventListener(\"click\", closeStats);\nstatsOverlay.addEventListener(\"click\", e => { if (e.target === statsOverlay) closeStats(); });\n\n/* ── Export / Import the whole list (portable across browsers & devices) ── */\ndocument.getElementById(\"stExport\").addEventListener(\"click\", () => {\n  const payload = { app: \"anime-tierlist\", v: 2, savedAt: new Date().toISOString(), state };\n  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: \"application/json\" });\n  const a = document.createElement(\"a\");\n  a.href = URL.createObjectURL(blob);\n  a.download = \"anime-tierlist-\" + new Date().toISOString().slice(0, 10) + \".json\";\n  a.click();\n  setTimeout(() => URL.revokeObjectURL(a.href), 1500);\n  toast(\"Список сохранён в файл ⤓\");\n});\nconst importFile = document.getElementById(\"importFile\");\ndocument.getElementById(\"stImport\").addEventListener(\"click\", () => importFile.click());\nimportFile.addEventListener(\"change\", () => {\n  const f = importFile.files && importFile.files[0];\n  if (!f) return;\n  const reader = new FileReader();\n  reader.onload = () => {\n    try {\n      const parsed = JSON.parse(reader.result);\n      const st = parsed && parsed.state ? parsed.state : parsed;   /* accept wrapped or raw state */\n      if (!st || !Array.isArray(st.tiers)) throw new Error(\"bad\");\n      if (!confirm(\"Заменить текущий список импортированным? Обложки и реакции сохранятся.\")) { importFile.value = \"\"; return; }\n      state = migrateAndBackfillState(st);\n      save(); closeStats(); render();\n      toast(\"Список загружен ✓\");\n    } catch (e) { toast(\"Не удалось прочитать файл\"); }\n    importFile.value = \"\";\n  };\n  reader.readAsText(f);\n});\n\nconst editBtn = document.getElementById(\"editBtn\");\neditBtn.addEventListener(\"click\", () => {\n  editing = !editing;\n  document.body.classList.toggle(\"editing\", editing);\n  editBtn.classList.toggle(\"on\", editing);\n  setDraggable(editing);\n  if (editing) toast(\"Режим: перетаскивай тайтлы, чтобы менять порядок и тир\"); else toast(\"Готово\");\n});\ndocument.getElementById(\"addBtn\").addEventListener(\"click\", () => openModal(null, \"S\"));\ndocument.getElementById(\"resetBtn\").addEventListener(\"click\", () => {\n  if (!confirm(\"Сбросить тир-лист к исходному состоянию? Все изменения будут потеряны.\")) return;\n  state = defaultState(); save(); render(); toast(\"Сброшено к исходному\");\n});\n\n/* keyboard shortcuts:  /  search · N add · E edit · G grid · C chips */\nfunction initShortcuts() {\n  document.addEventListener(\"keydown\", e => {\n    if (e.metaKey || e.ctrlKey || e.altKey) return;\n    const tag = (e.target.tagName || \"\").toLowerCase();\n    const typing = tag === \"input\" || tag === \"select\" || tag === \"textarea\" || e.target.isContentEditable;\n    if (e.key === \"/\" && !typing) { e.preventDefault(); searchInput.focus(); searchInput.select(); return; }\n    if (typing) return;\n    if (overlay.classList.contains(\"show\") || confirmOverlay.classList.contains(\"show\")) return;\n    switch (e.key.toLowerCase()) {\n      case \"n\": e.preventDefault(); openModal(null, \"S\"); break;\n      case \"e\": editBtn.click(); break;\n      case \"g\": setView(\"grid\"); break;\n      case \"c\": setView(\"chips\"); break;\n    }\n  });\n}\ninitShortcuts();\n\n/* ════════════════════ EXPORT PNG ════════════════════ */\ndocument.getElementById(\"exportBtn\").addEventListener(\"click\", async () => {\n  if (typeof html2canvas === \"undefined\") { toast(\"Библиотека экспорта не загрузилась\"); return; }\n  const node = document.getElementById(\"capture\");\n  const wasEditing = editing;\n  if (editing) { editing = false; document.body.classList.remove(\"editing\"); editBtn.classList.remove(\"on\"); }\n  hidePreview();\n  document.body.classList.add(\"exporting\"); node.classList.add(\"exporting\");\n  toast(\"Готовлю изображение…\");\n  await new Promise(r => setTimeout(r, 120));\n  try {\n    const canvas = await html2canvas(node, { backgroundColor: \"#08060f\", scale: 2, useCORS: true, logging: false, windowWidth: node.scrollWidth });\n    const link = document.createElement(\"a\");\n    link.download = \"anime-tier-list.png\";\n    link.href = canvas.toDataURL(\"image/png\");\n    link.click();\n    toast(\"Сохранено в PNG ✓\");\n  } catch (err) {\n    toast(\"Не удалось экспортировать обложки (CORS). Попробуй вид «Чипы».\");\n  } finally {\n    document.body.classList.remove(\"exporting\"); node.classList.remove(\"exporting\");\n    if (wasEditing) { editing = true; document.body.classList.add(\"editing\"); editBtn.classList.add(\"on\"); }\n  }\n});\n\n/* ════════════════════ HOVER PREVIEW ════════════════════ */\nconst preview = document.getElementById(\"preview\");\nconst pImg = preview.querySelector(\"img\");\nconst pT = preview.querySelector(\".t\");\nconst pS = preview.querySelector(\".s\");\nconst pWlist = preview.querySelector(\".wlist\");\nconst pRank = preview.querySelector(\".pv-rank\");\nconst pRx = preview.querySelector(\".pv-rx\");\nlet pHide;\nfunction showPreview(el, uid) {\n  if (editing) return;\n  const f = findItem(uid); if (!f) return;\n  clearTimeout(pHide);\n  preview.dataset.tier = f.tier.id;\n  pRank.textContent = \"#\" + (f.tier.items.indexOf(f.item) + 1);\n  pRx.innerHTML = reactionHtml(f.item);\n  pT.textContent = f.item.name;\n  pS.textContent = f.tier.id + \"-tier · \" + f.tier.label;\n  const _wl = normWatched(f.item.watched);\n  pWlist.innerHTML = _wl.map(e => `<div class=\"wrow-p\"><span>${e.label ? esc(e.label) : \"Просмотр\"}<\u002Fspan><b>${esc(e.date)} г.<\u002Fb><\u002Fdiv>`).join(\"\");\n  const cover = f.item.cover || COVERS[f.item.name] || \"\";\n  pImg.classList.remove(\"loaded\");\n  if (cover) { pImg.onload = () => pImg.classList.add(\"loaded\"); pImg.src = cover; } else { pImg.removeAttribute(\"src\"); }\n  const r = el.getBoundingClientRect();\n  const below = r.top < 380;\n  preview.classList.toggle(\"below\", below);\n  preview.style.left = (r.left + r.width / 2) + \"px\";\n  preview.style.top = (below ? r.bottom : r.top) + \"px\";\n  preview.classList.add(\"show\");\n}\nfunction hidePreview() { preview.classList.remove(\"show\"); pHide = setTimeout(() => pImg.removeAttribute(\"src\"), 200); }\naddEventListener(\"scroll\", hidePreview, { passive: true });\n\n/* ════════════════════ WINGS FLARE (hover flourish) ════════════════════ */\nconst wingsEl = document.getElementById(\"wings\");\nconst reduceMotion = matchMedia(\"(prefers-reduced-motion: reduce)\").matches;\nlet wingsT;\nfunction flareWings(card, tierId) {\n  if (editing || reduceMotion || !wingsEl) return;\n  const r = card.getBoundingClientRect();\n  wingsEl.style.left = (r.left + r.width / 2) + \"px\";\n  wingsEl.style.top = (r.top + r.height / 2) + \"px\";\n  wingsEl.style.width = r.width + \"px\";\n  wingsEl.style.height = r.height + \"px\";\n  wingsEl.dataset.tier = tierId || \"S\";\n  wingsEl.classList.remove(\"show\");\n  void wingsEl.offsetWidth;                 /* reflow → restart the one-shot animation */\n  wingsEl.classList.add(\"show\");\n  clearTimeout(wingsT);\n  wingsT = setTimeout(() => wingsEl.classList.remove(\"show\"), 2200);\n}\naddEventListener(\"scroll\", () => wingsEl && wingsEl.classList.remove(\"show\"), { passive: true });\n\n/* ════════════════════ TOAST ════════════════════ */\nlet toastT;\nfunction toast(msg) {\n  const t = document.getElementById(\"toast\");\n  t.querySelector(\".toast-txt\").textContent = msg;\n  t.classList.add(\"show\");\n  clearTimeout(toastT);\n  toastT = setTimeout(() => t.classList.remove(\"show\"), 2200);\n}\n\n/* stamp */\ndocument.getElementById(\"stamp\").textContent = \"v · \" + new Date().toLocaleDateString(\"ru-RU\");\n\nrender();\n\n/* ════════════════════ PARALLAX ════════════════════ */\nconst root = document.documentElement;\nconst isTouch = matchMedia(\"(hover: none)\").matches;\nlet mx = 0, my = 0, pScheduled = false;\nif (!isTouch) {\n  addEventListener(\"mousemove\", e => {\n    mx = (e.clientX / innerWidth - 0.5) * 2;\n    my = (e.clientY / innerHeight - 0.5) * 2;\n    if (!pScheduled) { pScheduled = true; requestAnimationFrame(() => { root.style.setProperty(\"--mx\", mx); root.style.setProperty(\"--my\", my); pScheduled = false; }); }\n  }, { passive: true });\n}\n\n/* ════════════════════ EFFECTS PANEL + INTERACTIONS ════════════════════ */\n(function(){\n  const FX_KEY = \"anime-tierlist-fx\";\n  const body = document.body;\n  const isTouchDev = matchMedia(\"(hover: none)\").matches;\n  const lowDev = isTouchDev || innerWidth < 720 || (navigator.hardwareConcurrency && navigator.hardwareConcurrency <= 4);\n  const defaults = { \"fx-neon\": true, \"fx-tilt\": !isTouchDev, \"fx-cursor\": !isTouchDev, \"fx-particles\": !lowDev, \"fx-petals\": !lowDev, glow: 1, atm: \"midnight\", rhythm: \"standard\", glass: \"standard\" };\n  let cfg;\n  try { cfg = Object.assign({}, defaults, JSON.parse(localStorage.getItem(FX_KEY) || \"{}\")); }\n  catch(e) { cfg = Object.assign({}, defaults); }\n\n  function apply() {\n    [\"fx-neon\",\"fx-tilt\",\"fx-cursor\",\"fx-particles\",\"fx-petals\"].forEach(k => body.classList.toggle(k, !!cfg[k]));\n    document.documentElement.style.setProperty(\"--glow-mult\", cfg.glow);\n    document.querySelectorAll(\".fx-sw\").forEach(sw => sw.classList.toggle(\"on\", !!cfg[sw.dataset.fx]));\n    const gl = document.getElementById(\"fxGlow\"); if (gl) gl.value = cfg.glow;\n    // expressive feel presets\n    const SEGS = { atm: [\"midnight\",\"ember\",\"abyss\",\"sakura\",\"shibuya\"], rhythm: [\"cozy\",\"standard\",\"grand\"], glass: [\"frosted\",\"standard\",\"crystal\"] };\n    const PREFIX = { atm: \"atm-\", rhythm: \"rhythm-\", glass: \"glass-\" };\n    Object.keys(SEGS).forEach(key => {\n      SEGS[key].forEach(v => body.classList.remove(PREFIX[key] + v));\n      body.classList.add(PREFIX[key] + cfg[key]);\n      document.querySelectorAll(`.fx-seg[data-seg=\"${key}\"] button`).forEach(b => b.classList.toggle(\"on\", b.dataset.v === cfg[key]));\n    });\n    window.dispatchEvent(new CustomEvent(\"fx-change\"));\n  }\n  function persist() { try { localStorage.setItem(FX_KEY, JSON.stringify(cfg)); } catch(e){} }\n  apply();\n\n  const panel = document.getElementById(\"fxPanel\");\n  document.getElementById(\"fxGear\").addEventListener(\"click\", e => { e.stopPropagation(); panel.classList.toggle(\"show\"); });\n  document.getElementById(\"fxClose\").addEventListener(\"click\", () => panel.classList.remove(\"show\"));\n  document.addEventListener(\"click\", e => { if (panel.classList.contains(\"show\") && !panel.contains(e.target) && !e.target.closest(\"#fxGear\")) panel.classList.remove(\"show\"); });\n  document.querySelectorAll(\".fx-sw\").forEach(sw => sw.addEventListener(\"click\", () => { cfg[sw.dataset.fx] = !cfg[sw.dataset.fx]; apply(); persist(); }));\n  document.querySelectorAll(\".fx-seg\").forEach(seg => seg.addEventListener(\"click\", e => {\n    const b = e.target.closest(\"button\"); if (!b) return;\n    cfg[seg.dataset.seg] = b.dataset.v; apply(); persist();\n  }));\n  const glow = document.getElementById(\"fxGlow\");\n  glow.addEventListener(\"input\", e => { cfg.glow = parseFloat(e.target.value); document.documentElement.style.setProperty(\"--glow-mult\", cfg.glow); });\n  glow.addEventListener(\"change\", persist);\n\n  /* cursor radial glow */\n  const cg = document.getElementById(\"cursorGlow\");\n  if (!isTouchDev) addEventListener(\"mousemove\", e => { cg.style.transform = `translate(${e.clientX}px, ${e.clientY}px)`; }, { passive: true });\n\n  /* 3D tilt toward cursor — for posters and tier badges (delegated, survives re-render) */\n  function tiltToward(el, e, vars, amt) {\n    const r = el.getBoundingClientRect();\n    const px = (e.clientX - r.left) / r.width - 0.5;\n    const py = (e.clientY - r.top) / r.height - 0.5;\n    el.style.setProperty(vars[0], (px * amt).toFixed(2) + \"deg\");\n    el.style.setProperty(vars[1], (-py * amt).toFixed(2) + \"deg\");\n  }\n  if (!isTouchDev) {\n    document.addEventListener(\"pointermove\", e => {\n      if (!body.classList.contains(\"fx-tilt\")) return;\n      const card = e.target.closest && e.target.closest(\".card\");\n      if (card) { tiltToward(card, e, [\"--rx\", \"--ry\"], 9); return; }\n      const badge = e.target.closest && e.target.closest(\".badge\");\n      if (badge) tiltToward(badge, e, [\"--brx\", \"--bry\"], 12);\n    }, { passive: true });\n    document.addEventListener(\"pointerout\", e => {\n      const card = e.target.closest && e.target.closest(\".card\");\n      if (card) { card.style.setProperty(\"--rx\", \"0deg\"); card.style.setProperty(\"--ry\", \"0deg\"); }\n      const badge = e.target.closest && e.target.closest(\".badge\");\n      if (badge) { badge.style.setProperty(\"--brx\", \"0deg\"); badge.style.setProperty(\"--bry\", \"0deg\"); }\n    }, { passive: true });\n  }\n})();\n<\u002Fscript>\n\n<script>\n/* ════════════════════ ABSTRACT AMBIENT CANVAS: drifting motes + soft orbs + sparks ════════════════════ */\n(() => {\n  const reduce = matchMedia(\"(prefers-reduced-motion: reduce)\").matches;\n  const rnd = (a, b) => a + Math.random() * (b - a);\n  const pick = a => a[Math.floor(Math.random() * a.length)];\n  if (reduce) return;\n\n  const cv = document.getElementById(\"fx\"), ctx = cv.getContext(\"2d\");\n  let W, H, dpr, running = true;\n  function resize() {\n    dpr = Math.min(window.devicePixelRatio || 1, 2);\n    W = innerWidth; H = innerHeight;\n    cv.width = W * dpr; cv.height = H * dpr; cv.style.width = W+\"px\"; cv.style.height = H+\"px\";\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n  resize();\n  addEventListener(\"resize\", resize);\n\n  let mX = W/2, mY = H/2;\n  if (!matchMedia(\"(hover: none)\").matches) addEventListener(\"mousemove\", e => { mX = e.clientX; mY = e.clientY; }, { passive: true });\n\n  /* brand palette — restrained neon, biased by chosen atmosphere */\n  const PALETTES = {\n    midnight: { orb: [\"rgba(53,224,214,\",\"rgba(105,176,255,\",\"rgba(167,121,255,\",\"rgba(255,92,149,\",\"rgba(255,194,77,\"], hue: [173, 215, 266, 336, 42] },\n    ember:    { orb: [\"rgba(255,92,149,\",\"rgba(255,138,96,\",\"rgba(255,194,77,\",\"rgba(255,158,196,\"], hue: [336, 18, 42, 350] },\n    abyss:    { orb: [\"rgba(53,224,214,\",\"rgba(105,176,255,\",\"rgba(120,200,255,\",\"rgba(167,121,255,\"], hue: [173, 200, 215, 250] },\n    sakura:   { orb: [\"rgba(167,121,255,\",\"rgba(255,158,196,\",\"rgba(209,155,255,\",\"rgba(255,92,149,\"], hue: [266, 320, 285, 336] },\n    shibuya:  { orb: [\"rgba(105,176,255,\",\"rgba(80,200,220,\",\"rgba(150,170,255,\",\"rgba(120,200,255,\"], hue: [205, 188, 225, 200] }\n  };\n  function atmKey() { for (const k of [\"ember\",\"abyss\",\"sakura\",\"shibuya\"]) if (document.body.classList.contains(\"atm-\" + k)) return k; return \"midnight\"; }\n  let ORB = PALETTES.midnight.orb, HUES = PALETTES.midnight.hue;\n  function pickPalette() { const p = PALETTES[atmKey()]; ORB = p.orb; HUES = p.hue; }\n  pickPalette();\n\n  /* fine drifting light dust — abstract, subtle */\n  class Mote {\n    constructor(seed) { this.reset(seed); }\n    reset(seed) {\n      this.x = Math.random()*W; this.y = seed ? Math.random()*H : H + 12;\n      this.r = rnd(0.7, 1.9); this.baseAlpha = rnd(.30, .8);\n      this.vx = rnd(-.18, .18); this.vy = rnd(-.34, -.08);\n      this.ph = rnd(0, Math.PI*2); this.tw = rnd(.010, .026);\n      this.hue = pick(HUES);\n    }\n    update() {\n      this.ph += this.tw;\n      this.x += this.vx + Math.sin(this.ph*0.7) * 0.24;\n      this.y += this.vy;\n      const dx = this.x - mX, dy = this.y - mY, d2 = dx*dx + dy*dy;\n      if (d2 < 17000) { const d = Math.sqrt(d2) || 1; const f = (1 - d/130) * 0.7; this.x += (dx/d)*f; this.y += (dy/d)*f; }\n      if (this.y < -18 || this.x < -22 || this.x > W + 22) this.reset(false);\n    }\n    draw() {\n      const a = this.baseAlpha * (0.34 + 0.66 * (0.5 + 0.5*Math.sin(this.ph)));\n      const R = this.r * 5;\n      const g = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, R);\n      g.addColorStop(0, `hsla(${this.hue},88%,74%,${a})`);\n      g.addColorStop(.45, `hsla(${this.hue},84%,62%,${a*0.32})`);\n      g.addColorStop(1, `hsla(${this.hue},84%,62%,0)`);\n      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(this.x, this.y, R, 0, Math.PI*2); ctx.fill();\n      ctx.fillStyle = `hsla(${this.hue},100%,90%,${a})`;\n      ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI*2); ctx.fill();\n    }\n  }\n  /* large soft out-of-focus orbs for depth */\n  class Orb {\n    constructor() { this.reset(true); }\n    reset(seed) {\n      this.x = Math.random()*W; this.y = seed ? Math.random()*H : H + 40;\n      this.r = rnd(40, 120); this.c = pick(ORB);\n      this.vy = rnd(.08, .26); this.vx = rnd(-.1, .1);\n      this.alpha = rnd(.03, .10); this.ph = rnd(0, Math.PI*2);\n    }\n    update() {\n      this.ph += 0.006;\n      this.y -= this.vy; this.x += this.vx + Math.sin(this.ph)*.24;\n      if (this.y < -130) this.reset(false);\n    }\n    draw() {\n      const g = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.r);\n      g.addColorStop(0, this.c + this.alpha + \")\");\n      g.addColorStop(1, this.c + \"0)\");\n      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI*2); ctx.fill();\n    }\n  }\n  /* occasional rising spark */\n  class Spark {\n    constructor() {\n      this.x = rnd(0, W); this.y = rnd(H*0.30, H*0.96);\n      this.life = 0; this.max = rnd(80, 160);\n      this.vy = rnd(-0.6, -0.2); this.vx = rnd(-0.26, 0.26);\n      this.r = rnd(.7, 1.5); this.hue = pick(HUES);\n    }\n    update() { this.life++; this.y += this.vy; this.x += this.vx; }\n    dead() { return this.life > this.max || this.y < -20; }\n    draw() {\n      const a = Math.sin((this.life / this.max) * Math.PI) * 0.7;\n      const R = this.r * 5;\n      const g = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, R);\n      g.addColorStop(0, `hsla(${this.hue},90%,82%,${a})`);\n      g.addColorStop(1, `hsla(${this.hue},88%,68%,0)`);\n      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(this.x, this.y, R, 0, Math.PI*2); ctx.fill();\n      ctx.fillStyle = `hsla(${this.hue},100%,92%,${a})`;\n      ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI*2); ctx.fill();\n    }\n  }\n\n  /* shooting light streak — a luminous comet that sweeps diagonally, leaving a fading trail */\n  class Streak {\n    constructor() {\n      const fromLeft = Math.random() < 0.5;\n      this.x = fromLeft ? rnd(-0.1*W, 0.2*W) : rnd(0.8*W, 1.1*W);\n      this.y = rnd(-0.05*H, 0.45*H);\n      const sp = rnd(7, 12), ang = (fromLeft ? rnd(0.18, 0.42) : Math.PI - rnd(0.18, 0.42));\n      this.vx = Math.cos(ang) * sp; this.vy = Math.sin(ang) * sp;\n      this.len = rnd(150, 320); this.w = rnd(1.4, 2.6);\n      this.life = 0; this.max = rnd(60, 110); this.hue = pick(HUES);\n    }\n    update() { this.life++; this.x += this.vx; this.y += this.vy; }\n    dead() { return this.life > this.max || this.x < -260 || this.x > W + 260 || this.y > H + 200; }\n    draw() {\n      const a = Math.sin((this.life / this.max) * Math.PI) * 0.55;\n      if (a <= 0) return;\n      const mag = Math.hypot(this.vx, this.vy) || 1;\n      const tx = this.x - (this.vx / mag) * this.len, ty = this.y - (this.vy / mag) * this.len;\n      const g = ctx.createLinearGradient(this.x, this.y, tx, ty);\n      g.addColorStop(0, `hsla(${this.hue},100%,90%,${a})`);\n      g.addColorStop(.35, `hsla(${this.hue},92%,72%,${a*0.5})`);\n      g.addColorStop(1, `hsla(${this.hue},90%,66%,0)`);\n      ctx.strokeStyle = g; ctx.lineWidth = this.w; ctx.lineCap = \"round\";\n      ctx.beginPath(); ctx.moveTo(this.x, this.y); ctx.lineTo(tx, ty); ctx.stroke();\n      // bright head\n      const hr = this.w * 2.4;\n      const hg = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, hr);\n      hg.addColorStop(0, `hsla(${this.hue},100%,94%,${a*1.1})`);\n      hg.addColorStop(1, `hsla(${this.hue},95%,78%,0)`);\n      ctx.fillStyle = hg; ctx.beginPath(); ctx.arc(this.x, this.y, hr, 0, Math.PI*2); ctx.fill();\n    }\n  }\n\n  /* drifting sakura petal — falls, sways, and flips in 3D as it tumbles down */\n  const PETAL_TINTS = [[255,182,206],[255,150,190],[255,210,228],[245,160,210]];\n  class Petal {\n    constructor(seed) { this.reset(seed); }\n    reset(seed) {\n      this.x = Math.random()*W;\n      this.y = seed ? Math.random()*H : -24;\n      this.size = rnd(7, 15);\n      this.vy = rnd(0.5, 1.2) * (this.size / 11);\n      this.sway = rnd(0.6, 1.7);\n      this.ph = rnd(0, Math.PI*2); this.swaySpeed = rnd(0.010, 0.022);\n      this.rot = rnd(0, Math.PI*2); this.vr = rnd(-0.02, 0.02);\n      this.flip = rnd(0.6, 1.5);\n      this.alpha = rnd(0.5, 0.92);\n      this.c = pick(PETAL_TINTS);\n    }\n    update() {\n      this.ph += this.swaySpeed;\n      this.x += Math.sin(this.ph) * this.sway + 0.14;\n      this.y += this.vy;\n      this.rot += this.vr;\n      if (this.y > H + 26) this.reset(false);\n      if (this.x > W + 32) this.x = -32;\n    }\n    draw() {\n      const w = this.size, h = this.size * 1.32;\n      ctx.save();\n      ctx.translate(this.x, this.y);\n      ctx.rotate(this.rot);\n      ctx.scale(Math.cos(this.ph * this.flip), 1); /* simulated tumble */\n      const g = ctx.createLinearGradient(0, -h/2, 0, h/2);\n      g.addColorStop(0, `rgba(255,236,245,${this.alpha})`);\n      g.addColorStop(1, `rgba(${this.c[0]},${this.c[1]},${this.c[2]},${this.alpha})`);\n      ctx.fillStyle = g;\n      ctx.beginPath();\n      ctx.moveTo(0, -h*0.5);\n      ctx.bezierCurveTo(w*0.55, -h*0.30, w*0.46, h*0.28, w*0.12, h*0.46);\n      ctx.quadraticCurveTo(0, h*0.32, -w*0.12, h*0.46); /* the sakura notch */\n      ctx.bezierCurveTo(-w*0.46, h*0.28, -w*0.55, -h*0.30, 0, -h*0.5);\n      ctx.fill();\n      ctx.restore();\n    }\n  }\n\n  /* one-shot celebratory burst — a ring of glowing sparks fired on a new entry */\n  let bursts = [];\n  function spawnBurst(x, y, hue) {\n    const n = lowDev ? 12 : 24;\n    if (bursts.length > 220) return;\n    for (let i = 0; i < n; i++) {\n      const ang = (i / n) * Math.PI * 2 + rnd(-0.18, 0.18);\n      const sp = rnd(1.6, 5.4);\n      bursts.push({ x, y, vx: Math.cos(ang)*sp, vy: Math.sin(ang)*sp - rnd(0, 1.1),\n        life: 0, max: rnd(34, 64), r: rnd(1.2, 3), hue: hue + rnd(-12, 12) });\n    }\n  }\n  function drawBursts() {\n    for (const p of bursts) {\n      p.life++; p.vy += 0.06; p.vx *= 0.985; p.x += p.vx; p.y += p.vy;\n      const a = Math.max(0, 1 - p.life / p.max) * 0.9;\n      if (a <= 0) continue;\n      const R = p.r * 4;\n      const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, R);\n      g.addColorStop(0, `hsla(${p.hue},100%,88%,${a})`);\n      g.addColorStop(1, `hsla(${p.hue},95%,70%,0)`);\n      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(p.x, p.y, R, 0, Math.PI*2); ctx.fill();\n      ctx.fillStyle = `hsla(${p.hue},100%,95%,${a})`;\n      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI*2); ctx.fill();\n    }\n    bursts = bursts.filter(p => p.life < p.max);\n  }\n  /* exposed so the app can fire a burst from a tier badge on add/edit */\n  window.__fxBurst = (x, y, hue) => { spawnBurst(x, y, hue == null ? pick(HUES) : hue); };\n\n  /* slanted luminous rain — used by the «Дождливая Сибуя» atmosphere */\n  class Rain {\n    constructor(seed) { this.reset(seed); }\n    reset(seed) {\n      this.x = Math.random() * (W + 140) - 70;\n      this.y = seed ? Math.random() * H : rnd(-40, -6);\n      this.len = rnd(12, 27); this.vy = rnd(9, 16); this.vx = rnd(1.1, 2.5);\n      this.a = rnd(.16, .5); this.w = rnd(.8, 1.5);\n    }\n    update() { this.y += this.vy; this.x += this.vx; if (this.y > H + 26) this.reset(false); }\n    draw() {\n      ctx.strokeStyle = `rgba(175,212,255,${this.a})`; ctx.lineWidth = this.w; ctx.lineCap = \"round\";\n      ctx.beginPath(); ctx.moveTo(this.x, this.y); ctx.lineTo(this.x - this.vx * 1.4, this.y - this.len); ctx.stroke();\n    }\n  }\n\n  const lowDev = innerWidth < 720 || matchMedia(\"(hover: none)\").matches;\n  function counts() {\n    const parts = document.body.classList.contains(\"fx-particles\");\n    const petalsOn = document.body.classList.contains(\"fx-petals\");\n    const shibuya = atmKey() === \"shibuya\";\n    return {\n      mote: lowDev ? 18 : (parts ? 52 : 32),\n      orb:  lowDev ? 6  : (parts ? 16 : 10),\n      sparkMax: parts ? (lowDev ? 2 : 6) : 0,\n      streakMax: lowDev ? 0 : (parts ? 3 : 2),\n      streakRate: parts ? 0.006 : 0.0035,\n      petal: (!shibuya && petalsOn) ? (lowDev ? 9 : 22) : 0,   /* sakura → off when raining */\n      rain: shibuya ? (lowDev ? 60 : 150) : 0\n    };\n  }\n  let motes = [], orbs = [], sparks = [], streaks = [], petals = [], rain = [], C = counts();\n  function seed() {\n    C = counts();\n    pickPalette();\n    motes = Array.from({length: C.mote}, () => new Mote(true));\n    orbs  = Array.from({length: C.orb},  () => new Orb());\n    petals = Array.from({length: C.petal}, () => new Petal(true));\n    rain = Array.from({length: C.rain}, () => new Rain(true));\n    if (sparks.length > C.sparkMax) sparks.length = C.sparkMax;\n    if (streaks.length > C.streakMax) streaks.length = C.streakMax;\n  }\n  seed();\n  addEventListener(\"resize\", seed);\n  addEventListener(\"fx-change\", seed);\n  /* pause when tab hidden */\n  document.addEventListener(\"visibilitychange\", () => { running = !document.hidden; if (running) requestAnimationFrame(loop); });\n\n  function loop() {\n    if (!running) return;\n    ctx.clearRect(0, 0, W, H);\n    ctx.globalCompositeOperation = \"screen\";\n    for (const o of orbs) { o.update(); o.draw(); }\n    if (C.sparkMax > 0) {\n      if (sparks.length < C.sparkMax && Math.random() < 0.014) sparks.push(new Spark());\n      for (const sp of sparks) { sp.update(); sp.draw(); }\n      sparks = sparks.filter(s => !s.dead());\n    }\n    for (const m of motes) { m.update(); m.draw(); }\n    if (C.streakMax > 0) {\n      if (streaks.length < C.streakMax && Math.random() < C.streakRate) streaks.push(new Streak());\n      for (const st of streaks) { st.update(); st.draw(); }\n      streaks = streaks.filter(s => !s.dead());\n    }\n    if (rain.length) { for (const rn of rain) { rn.update(); rn.draw(); } }   /* luminous rain (screen) */\n    if (bursts.length) drawBursts();          /* additive sparks (still in screen mode) */\n    if (petals.length) {                       /* blossoms fall in front, with body */\n      ctx.globalCompositeOperation = \"source-over\";\n      for (const pt of petals) { pt.update(); pt.draw(); }\n    }\n    ctx.globalCompositeOperation = \"source-over\";\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n})();\n<\u002Fscript>\n\n\n\n\n<\u002Fbody><\u002Fhtml>"
   </script>
