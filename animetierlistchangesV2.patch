lassList.remove(\"drag-over\"));\n}\n/* resolve { tier, beforeUid } from a drag event over the board */\nfunction dropTarget(e) {\n  const tierEl = e.target.closest(\".tier\");\n  const toTier = tierEl ? tierEl.dataset.tier : null;\n  let beforeUid = null;\n  const over = e.target.closest(\".card, .chip\");\n  if (over && +over.dataset.uid !== dragUid) {\n    const r = over.getBoundingClientRect();\n    const after = e.clientX > r.left + r.width / 2;\n    if (after) {\n      let n = over.nextElementSibling;\n      while (n && !n.matches(\".card, .chip\")) n = n.nextElementSibling;\n      beforeUid = n ? +n.dataset.uid : null;\n    } else { beforeUid = +over.dataset.uid; }\n  }\n  return { toTier, beforeUid, over, tierEl };\n}\nboard.addEventListener(\"dragstart\", e => {\n  const it = e.target.closest(\".card, .chip\");\n  if (!it || !editing) return;\n  dragUid = +it.dataset.uid;\n  it.classList.add(\"dragging\");\n  hidePreview();\n  e.dataTransfer.effectAllowed = \"move\";\n  try { e.dataTransfer.setData(\"text/plain\", String(dragUid)); } catch (_) {}\n});\nboard.addEventListener(\"dragend\", () => { document.querySelectorAll(\".dragging\").forEach(el => el.classList.remove(\"dragging\")); clearDropMarks(); dragUid = null; });\nboard.addEventListener(\"dragover\", e => {\n  if (dragUid == null) return;\n  e.preventDefault();\n  e.dataTransfer.dropEffect = \"move\";\n  clearDropMarks();\n  const { over, tierEl } = dropTarget(e);\n  if (tierEl) tierEl.classList.add(\"drag-over\");\n  if (over && +over.dataset.uid !== dragUid) {\n    const r = over.getBoundingClientRect();\n    over.classList.add(e.clientX > r.left + r.width / 2 ? \"drop-after\" : \"drop-before\");\n  }\n});\nboard.addEventListener(\"drop\", e => {\n  if (dragUid == null) return;\n  e.preventDefault();\n  const { toTier, beforeUid } = dropTarget(e);\n  const u = dragUid; dragUid = null; clearDropMarks();\n  if (toTier) { moveItem(u, toTier, beforeUid); toast(\"Перемещено\"); }\n});\n\n/* ── touch /