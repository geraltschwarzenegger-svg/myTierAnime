-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"adb1b4a7-c0e8-4658-b976-829d3b43e68e\") format('woff2');\n  unicode-range: U+a9, U+3010-3011, U+30e2, U+4e0b, U+4eca, U+4ed6, U+4ed8, U+4f53, U+4f5c, U+4f7f, U+53d6, U+540d, U+54c1, U+5730, U+5916, U+5b50, U+5c0f, U+5f8c, U+624b, U+6570, U+6587, U+6599, U+691c, U+696d, U+6cd5, U+7269, U+7279, U+7406, U+767a-767b, U+77e5, U+7d04, U+7d22, U+8005, U+80fd, U+81ea, U+8868, U+8981, U+89a7, U+901a, U+9023, U+90e8, U+91d1, U+9332, U+958b, U+96c6, U+9ad8, U+ff1a, U+ff1f;\n}\n@font-face {\n  font-family: 'Shippori Mincho';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"8251a5ab-fe91-412b-bc76-f3be9ae66153\") format('woff2');\n  unicode-range: U+4e, U+a0, U+3000, U+300c-300d, U+4e00, U+4e0a, U+4e2d, U+4e8b, U+4eba, U+4f1a, U+5165, U+5168, U+5185, U+51fa, U+5206, U+5229, U+524d, U+52d5, U+5408, U+554f, U+5831, U+5834, U+5927, U+5b9a, U+5e74, U+5f0f, U+60c5, U+65b0, U+65b9, U+6642, U+6700, U+672c, U+682a, U+6b63, U+6c17, U+7121, U+751f, U+7528, U+753b, U+76ee, U+793e, U+884c, U+898b, U+8a18, U+9593, U+95a2, U+ff01, U+ff08-ff09;\n}\n@font-face {\n  font-family: 'Shippori Mincho';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"0e2d527e-996c-4297-a826-29afeda0ae37\") format('woff2');\n  unicode-range: U+21-22, U+27-2a, U+2c-3b, U+3f, U+41-4d, U+4f-5d, U+61-7b, U+7d, U+ab, U+ae, U+b2-b3, U+b7, U+bb, U+c9, U+cd, U+d6, U+d8, U+dc, U+e0-e5, U+e7-ed, U+ef, U+f1-f4, U+f6, U+f8, U+fa, U+fc-fd, U+103, U+14d, U+1b0, U+300-301, U+1ebf, U+1ec7, U+2013-2014, U+201c-201d, U+2039-203a, U+203c, U+2048-2049, U+2113, U+2122, U+65e5, U+6708, U+70b9;\n}\n@font-face {\n  font-family: 'Shippori Mincho';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"ea6f921a-acd1-4b79-b049-e23b1a91b4d5\") format('woff2');\n  unicode-range: U+20, U+2027, U+3001-3002, U+3041-307f, U+3081-308f, U+3091-3093, U+3099-309a, U+309d-309e, U+30a1-30e1, U+30e3-30ed, U+30ef-30f0, U+30f2-30f4, U+30fb-30fe, U+ff0c, U+ff0e;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Shippori Mincho';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"141d0fd8-0a7c-4347-9b40-4b03ce601c25\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Shippori Mincho';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"1349db67-618b-4166-96eb-e64d870dff9e\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<script src=\"08dfd0a8-0dca-4e29-91a3-21b3583c3706\"><\u002Fscript>\n<style>\n  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }\n\n  :root {\n    --bg-0: #07060e;\n    --bg-1: #0c0a1a;\n    --bg-2: #120e24;\n\n    --ink:        #f6f4ff;\n    --ink-soft:   #cfc8e6;\n    --ink-faint:  #8f86ad;\n    --rule:       rgba(255,255,255,0.10);\n    --glass:      rgba(255,255,255,0.045);\n    --glass-2:    rgba(255,255,255,0.07);\n    --glass-line: rgba(255,255,255,0.10);\n\n    --s:  #ff5c95; --s2: #ff9ec4; --s-g: rgba(255,92,149,0.55);\n    --a:  #35e0d6; --a2: #69b0ff; --a-g: rgba(53,224,214,0.50);\n    --b:  #a779ff; --b2: #d09bff; --b-g: rgba(167,121,255,0.52);\n    --c:  #ffc24d; --c2: #ffe09a; --c-g: rgba(255,194,77,0.50);\n\n    /* S-tier elite — gold + crimson royal */\n    --gold: #ffd76a; --gold2: #fff3cf; --gold-g: rgba(255,200,90,0.55);\n    --crimson: #e0356b; --crimson-deep: #a8123f; --crimson-g: rgba(224,53,107,0.5);\n\n    --serif: 'Prata', Georgia, serif;\n    --sans:  'Manrope', system-ui, sans-serif;\n    --jp:    'Shippori Mincho', serif;\n\n    --mx: 0; --my: 0;\n    --radius: 18px;\n\n    /* ── feel: aurora atmosphere palette (overridden by body.atm-*) ── */\n    --base-top: #14102a;\n    --au-a: rgba(255,92,149,0.20);\n    --au-b: rgba(53,224,214,0.17);\n    --au-c: rgba(167,121,255,0.19);\n    --au-d: rgba(255,194,77,0.11);\n    --au2a: rgba(105,176,255,0.13);\n    --au2b: rgba(167,121,255,0.12);\n    --au2c: rgba(255,92,149,0.10);\n\n    /* ── feel: glass surface character (overridden by body.glass-*) ── */\n    --panel-blur: 20px;\n    --surface-hi: .05;\n    --surface-lo: .018;\n    --surface-fill: transparent;\n  }\n\n  html { scroll-behavior: smooth; }\n  body {\n    min-height: 100vh;\n    font-family: var(--sans);\n    color: var(--ink);\n    background: var(--bg-0);\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    position: relative;\n  }\n  ::selection { background: rgba(255,92,149,0.32); color: #fff; }\n\n  /* ─────────────────────────  ABSTRACT DIGITAL ENVIRONMENT  ───────────────────────── */\n  .bg { position: fixed; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }\n\n  /* deep foundation: graphite → midnight navy → muted violet */\n  .bg-base {\n    position: absolute; inset: 0;\n    background:\n      radial-gradient(130% 100% at 50% -10%, var(--base-top) 0%, #0b0918 42%, #07060e 100%);\n    transition: background 1.1s ease;\n  }\n\n  /* ── Japanese scene: distant Mt. Fuji, rising sun, torii & drifting clouds ──\n     A self-contained ukiyo-e silhouette (no external image) that anchors to the\n     foot of the viewport and reads instantly as anime / Japan without fighting\n     the reading zone. Subtle parallax + slow ambient motion give it life.      */\n  .scene-jp {\n    position: absolute; inset: 0; z-index: 0; opacity: .55; pointer-events: none;\n    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 24%, #000 100%);\n    mask-image: linear-gradient(to bottom, transparent 0%, #000 24%, #000 100%);\n    transform: translate3d(calc(var(--mx) * -7px), calc(var(--my) * -4px), 0);\n    transition: opacity 1.1s ease;\n  }\n  .scene-jp svg { position: absolute; inset: 0; width: 100%; height: 100%; }\n  .scene-jp .jp-sun, .scene-jp .jp-clouds, .scene-jp .jp-clouds2, .scene-jp .jp-birds { transform-box: view-box; }\n  .scene-jp .jp-sun {\n    transform-origin: 770px 252px;\n    animation: jpSunBreathe 11s ease-in-out infinite alternate;\n  }\n  @keyframes jpSunBreathe { 0% { opacity: .82; transform: scale(.985); } 100% { opacity: 1; transform: scale(1.045); } }\n  .scene-jp .jp-clouds  { animation: jpDrift 52s linear infinite; }\n  .scene-jp .jp-clouds2 { animation: jpDrift 78s linear infinite reverse; }\n  @keyframes jpDrift { 0% { transform: translateX(-46px); } 100% { transform: translateX(46px); } }\n  .scene-jp .jp-birds { animation: jpFlyby 34s linear infinite; }\n  @keyframes jpFlyby {\n    0% { transform: translate(-80px, 36px); opacity: 0; }\n    9% { opacity: .7; } 60% { opacity: .55; } 94% { opacity: .35; }\n    100% { transform: translate(460px, -54px); opacity: 0; }\n  }\n  body.atm-ember  .scene-jp { opacity: .6; }\n  body.atm-sakura .scene-jp { opacity: .6; }\n  @media (max-width: 720px) { .scene-jp { opacity: .4; } .scene-jp .jp-birds { display: none; } }\n\n  /* primary aurora mesh — layered blurred fields, slow drift + rotate */\n  .aurora {\n    position: absolute; inset: -30%;\n    background:\n      radial-gradient(34% 40% at 20% 24%, var(--au-a), transparent 68%),\n      radial-gradient(36% 42% at 82% 20%, var(--au-b), transparent 70%),\n      radial-gradient(44% 48% at 70% 72%, var(--au-c), transparent 70%),\n      radial-gradient(36% 40% at 26% 82%, var(--au-d), transparent 72%);\n    filter: blur(38px) saturate(124%);\n    animation: aurora-drift 42s ease-in-out infinite alternate;\n    transform: translate3d(calc(var(--mx) * 12px), calc(var(--my) * 12px), 0);\n    will-change: transform; transition: background 1.1s ease;\n  }\n  @keyframes aurora-drift {\n    0%   { transform: translate3d(calc(var(--mx) * 12px), calc(var(--my) * 12px), 0) scale(1) rotate(0deg); }\n    100% { transform: translate3d(calc(var(--mx) * 12px), calc(var(--my) * 12px), 0) scale(1.14) rotate(7deg); }\n  }\n\n  /* secondary counter-rotating mesh — adds spatial depth */\n  .aurora-2 {\n    position: absolute; inset: -34%;\n    background:\n      radial-gradient(30% 34% at 64% 18%, var(--au2a), transparent 66%),\n      radial-gradient(32% 36% at 14% 60%, var(--au2b), transparent 68%),\n      radial-gradient(28% 32% at 88% 64%, var(--au2c), transparent 70%);\n    filter: blur(58px) saturate(118%);\n    animation: aurora-drift-2 64s ease-in-out infinite alternate;\n    transform: translate3d(calc(var(--mx) * -8px), calc(var(--my) * -8px), 0);\n    will-change: transform; opacity: .9; transition: background 1.1s ease;\n  }\n  @keyframes aurora-drift-2 {\n    0%   { transform: translate3d(calc(var(--mx) * -8px), calc(var(--my) * -8px), 0) scale(1.08) rotate(0deg); }\n    100% { transform: translate3d(calc(var(--mx) * -8px), calc(var(--my) * -8px), 0) scale(1) rotate(-9deg); }\n  }\n\n  /* subtle geometric layer — faint grid, fades toward edges */\n  .grid-layer {\n    position: absolute; inset: 0; opacity: .5;\n    background-image:\n      linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);\n    background-size: 58px 58px, 58px 58px;\n    -webkit-mask-image: radial-gradient(120% 95% at 50% 38%, transparent 30%, #000 100%);\n    mask-image: radial-gradient(120% 95% at 50% 38%, transparent 30%, #000 100%);\n    transform: translate3d(calc(var(--mx) * 5px), calc(var(--my) * 5px), 0);\n  }\n\n  /* translucent geometric glass shards — soft drifting planes */\n  .shard {\n    position: absolute; border-radius: 30px;\n    background: linear-gradient(150deg, rgba(255,255,255,0.04), rgba(255,255,255,0.005));\n    border: 1px solid rgba(255,255,255,0.05);\n    backdrop-filter: blur(2px); will-change: transform;\n  }\n  .shard.s1 { width: 360px; height: 360px; top: 12vh; left: -120px; transform: rotate(24deg) translate3d(calc(var(--mx)*-14px), calc(var(--my)*-10px), 0); animation: shardFloat 28s ease-in-out infinite alternate; }\n  .shard.s2 { width: 280px; height: 280px; top: 56vh; right: -90px; transform: rotate(-18deg) translate3d(calc(var(--mx)*16px), calc(var(--my)*12px), 0); animation: shardFloat 34s ease-in-out infinite alternate-reverse; }\n  @keyframes shardFloat { 0% { translate: 0 0; } 100% { translate: 0 -26px; } }\n\n  #fx { position: absolute; inset: 0; width: 100%; height: 100%; }\n\n  /* calm, darker reading zone behind the central tier list */\n  .center-calm {\n    position: absolute; inset: 0;\n    background: radial-gradient(58% 60% at 50% 48%, rgba(6,5,13,0.62) 0%, rgba(6,5,13,0.28) 46%, transparent 78%);\n  }\n\n  .bg-tint {\n    position: absolute; inset: 0;\n    background:\n      linear-gradient(to bottom, rgba(7,6,14,0.42) 0%, rgba(7,6,14,0.08) 26%, rgba(7,6,14,0.30) 82%, rgba(6,5,12,0.72) 100%);\n  }\n\n  .grain {\n    position: fixed; inset: 0; z-index: 1; pointer-events: none;\n    opacity: .035; mix-blend-mode: overlay;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\");\n  }\n  .vignette {\n    position: fixed; inset: 0; z-index: 1; pointer-events: none;\n    background: radial-gradient(circle at 50% 42%, transparent 52%, rgba(4,3,9,0.66) 100%);\n  }\n  @media (max-width: 720px) {\n    .shard { display: none; }\n    .aurora-2 { display: none; }\n  }\n\n  /* ═══════════ FEEL PRESETS (tweaks) ═══════════ */\n  /* Atmosphere — reshapes the whole background palette (tier identity untouched) */\n  body.atm-ember {\n    --base-top: #1d1226;\n    --au-a: rgba(255,92,149,0.26); --au-b: rgba(255,138,96,0.17);\n    --au-c: rgba(167,121,255,0.09); --au-d: rgba(255,194,77,0.21);\n    --au2a: rgba(255,138,96,0.13); --au2b: rgba(255,92,149,0.13); --au2c: rgba(255,194,77,0.10);\n  }\n  body.atm-abyss {\n    --base-top: #0a1628;\n    --au-a: rgba(53,224,214,0.22); --au-b: rgba(105,176,255,0.21);\n    --au-c: rgba(167,121,255,0.12); --au-d: rgba(53,224,214,0.10);\n    --au2a: rgba(105,176,255,0.16); --au2b: rgba(53,224,214,0.13); --au2c: rgba(105,176,255,0.10);\n  }\n  body.atm-sakura {\n    --base-top: #1a1030;\n    --au-a: rgba(255,92,149,0.20); --au-b: rgba(167,121,255,0.23);\n    --au-c: rgba(209,155,255,0.20); --au-d: rgba(255,158,196,0.14);\n    --au2a: rgba(167,121,255,0.16); --au2b: rgba(255,158,196,0.13); --au2c: rgba(209,155,255,0.11);\n  }\n\n  /* Card rhythm — reshapes the grid density & poster scale */\n  body.rhythm-cozy  .items.grid { grid-template-columns: repeat(auto-fill, minmax(94px, 1fr));  gap: 9px; }\n  body.rhythm-grand .items.grid { grid-template-columns: repeat(auto-fill, minmax(154px, 1fr)); gap: 16px; }\n  body.rhythm-grand .card .nm { font-size: 13px; padding: 11px 12px; }\n\n  /* Glass — reshapes surface depth across panels & toolbar */\n  body.glass-frosted { --panel-blur: 30px; --surface-hi: .055; --surface-lo: .02; --surface-fill: rgba(15,12,27,0.52); }\n  body.glass-crystal { --panel-blur: 8px;  --surface-hi: .075; --surface-lo: .008; --surface-fill: transparent; }\n  body.glass-crystal .panel { box-shadow: 0 26px 64px -34px rgba(0,0,0,.92), inset 0 1px 0 rgba(255,255,255,.12), inset 1px 0 0 color-mix(in srgb, var(--t) 28%, transparent); }\n\n  /* ─────────────────────────  TOOLBAR  ───────────────────────── */\n  .toolbar {\n    position: sticky; top: 12px; z-index: 60;\n    display: flex; align-items: center; gap: 14px;\n    margin: 14px clamp(12px, 3vw, 28px) 0;\n    padding: 11px clamp(12px, 2vw, 18px);\n    border-radius: 18px;\n    background: linear-gradient(160deg, rgba(22,17,38,0.72), rgba(12,10,24,0.62));\n    border: 1px solid rgba(255,255,255,0.09);\n    backdrop-filter: blur(calc(var(--panel-blur) + 2px)) saturate(150%);\n    -webkit-backdrop-filter: blur(calc(var(--panel-blur) + 2px)) saturate(150%);\n    box-shadow: 0 22px 54px -26px rgba(0,0,0,.85), inset 0 1px 0 rgba(255,255,255,.07);\n  }\n  .brand { display: flex; align-items: center; gap: 12px; }\n  .brand .mark {\n    width: 38px; height: 38px; border-radius: 11px; flex: none;\n    display: grid; place-items: center;\n    background: linear-gradient(150deg, var(--s), var(--b));\n    box-shadow: 0 8px 24px -6px var(--s-g), inset 0 1px 0 rgba(255,255,255,.3);\n    font-family: var(--jp); font-weight: 700; font-size: 18px; color: #fff;\n  }\n  .brand .txt { line-height: 1.05; }\n  .brand .txt b { font-family: var(--serif); font-weight: 400; font-size: 17px; letter-spacing: .01em; }\n  .brand .txt span { display: block; font-size: 10.5px; letter-spacing: .26em; text-transform: uppercase; color: var(--ink-faint); margin-top: 3px; }\n  .tb-spacer { flex: 1; }\n\n  .seg {\n    display: inline-flex; padding: 4px; gap: 4px; border-radius: 999px;\n    background: var(--glass); border: 1px solid var(--glass-line);\n  }\n  .seg button {\n    border: 0; background: transparent; cursor: pointer;\n    color: var(--ink-faint); font-family: var(--sans); font-weight: 700; font-size: 12px;\n    letter-spacing: .04em; padding: 8px 14px; border-radius: 999px;\n    display: inline-flex; align-items: center; gap: 7px;\n    transition: color .2s, background .2s, box-shadow .2s;\n  }\n  .seg button svg { width: 15px; height: 15px; }\n  .seg button.on {\n    color: #fff;\n    background: linear-gradient(150deg, rgba(255,255,255,.16), rgba(255,255,255,.06));\n    box-shadow: 0 4px 14px -4px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.2);\n  }\n\n  .btn {\n    border: 1px solid var(--glass-line); background: var(--glass); cursor: pointer;\n    color: var(--ink-soft); font-family: var(--sans); font-weight: 700; font-size: 12px;\n    letter-spacing: .03em; padding: 9px 15px; border-radius: 999px;\n    display: inline-flex; align-items: center; gap: 8px;\n    transition: all .22s cubic-bezier(.2,.8,.2,1);\n  }\n  .btn svg { width: 15px; height: 15px; }\n  .btn:hover { color: #fff; border-color: rgba(255,255,255,.28); transform: translateY(-1px); background: var(--glass-2); }\n  .btn.primary {\n    color: #140a16; border-color: transparent;\n    background: linear-gradient(150deg, var(--s2), var(--s));\n    box-shadow: 0 10px 26px -8px var(--s-g);\n  }\n  .btn.primary:hover { filter: brightness(1.06); color: #140a16; }\n  .btn.on { color: #fff; border-color: var(--s); box-shadow: 0 0 0 1px var(--s) inset, 0 8px 22px -8px var(--s-g); background: rgba(255,92,149,.12); }\n  .btn .lbl-edit-off { display: inline; }\n  .btn .lbl-edit-on { display: none; }\n  .btn.on .lbl-edit-off { display: none; }\n  .btn.on .lbl-edit-on { display: inline; }\n\n  /* ─────────────────────────  PAGE  ───────────────────────── */\n  .page { position: relative; z-index: 2; max-width: 1140px; margin: 0 auto; padding: 26px clamp(16px,4vw,44px) 60px; }\n\n  .masthead { text-align: center; padding: 30px 0 46px; }\n  .masthead .jp {\n    font-family: var(--jp); font-size: 12.5px; letter-spacing: .54em; color: var(--ink-faint);\n    text-transform: none; margin-bottom: 18px; padding-left: .54em;\n  }\n  .masthead h1 {\n    font-family: var(--serif); font-weight: 400; font-size: clamp(42px, 7vw, 82px);\n    line-height: .98; letter-spacing: -0.015em; color: var(--ink);\n  }\n  .masthead h1 em {\n    font-style: normal;\n    background: linear-gradient(120deg, var(--s) 0%, var(--b) 38%, var(--a) 70%, var(--s) 100%);\n    background-size: 220% 100%;\n    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;\n    animation: titleFlow 14s ease-in-out infinite;\n  }\n  .masthead .deck { margin-top: 18px; font-size: 13.5px; letter-spacing: .05em; color: var(--ink-soft); }\n  .masthead .stats { margin-top: 24px; display: inline-flex; gap: 10px; flex-wrap: wrap; justify-content: center; }\n  .masthead .stat {\n    display: inline-flex; align-items: baseline; gap: 7px;\n    font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-faint);\n    padding: 9px 16px; border-radius: 999px;\n    background: rgba(255,255,255,.035); border: 1px solid rgba(255,255,255,.08);\n    backdrop-filter: blur(10px);\n  }\n  .masthead .stat b { font-family: var(--serif); font-size: 20px; letter-spacing: 0; color: var(--ink); }\n\n  /* ─────────────────────────  TIER  ───────────────────────── */\n  .board { display: flex; flex-direction: column; gap: 22px; }\n\n  .tier {\n    display: grid; grid-template-columns: 150px 1fr; gap: 18px; align-items: stretch;\n  }\n  .board.intro .tier { opacity: 0; transform: translateY(26px); animation: tier-in .7s cubic-bezier(.2,.8,.2,1) forwards; }\n  .board.intro .tier:nth-child(1) { animation-delay: .04s; }\n  .board.intro .tier:nth-child(2) { animation-delay: .12s; }\n  .board.intro .tier:nth-child(3) { animation-delay: .20s; }\n  .board.intro .tier:nth-child(4) { animation-delay: .28s; }\n  @keyframes tier-in { to { opacity: 1; transform: none; } }\n\n  .badge {\n    position: relative; border-radius: var(--radius);\n    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;\n    padding: 22px 10px;\n    background:\n      radial-gradient(120% 86% at 50% 0%, color-mix(in srgb, var(--t) 30%, transparent), transparent 60%),\n      linear-gradient(160deg, rgba(255,255,255,.075), rgba(255,255,255,.015));\n    border: 1px solid var(--glass-line);\n    backdrop-filter: blur(14px) saturate(135%); -webkit-backdrop-filter: blur(14px) saturate(135%);\n    box-shadow:\n      0 18px 46px -22px rgba(0,0,0,.9),\n      inset 0 1px 0 rgba(255,255,255,.10),\n      inset 0 0 0 1px rgba(255,255,255,.03),\n      0 0 60px -22px var(--tg);\n  }\n  /* soft atmospheric bloom behind the badge (not clipped) */\n  .badge::after {\n    content: \"\"; position: absolute; inset: -18% -14%; z-index: -1; border-radius: 50%;\n    background: radial-gradient(circle at 50% 42%, var(--tg), transparent 68%);\n    filter: blur(26px); opacity: calc(.7 * var(--glow-mult, 1)); pointer-events: none;\n    animation: badgeBloom 5.2s ease-in-out infinite alternate;\n  }\n  @keyframes badgeBloom { 0% { opacity: calc(.45 * var(--glow-mult,1)); transform: scale(.94); } 100% { opacity: calc(.85 * var(--glow-mult,1)); transform: scale(1.06); } }\n  .badge::before {\n    content: \"\"; position: absolute; inset: 0; border-radius: inherit; padding: 1.4px;\n    background: linear-gradient(150deg, var(--t), var(--t2), transparent 80%);\n    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);\n    -webkit-mask-composite: xor; mask-composite: exclude; opacity: .85; pointer-events: none; z-index: 2;\n  }\n  .badge .letter {\n    position: relative; z-index: 1; display: grid; place-items: center;\n    font-family: var(--serif); font-size: 74px; line-height: .86; font-weight: 400;\n    background: linear-gradient(162deg, #ffffff 0%, color-mix(in srgb, var(--t2) 78%, #fff) 40%, var(--t) 100%);\n    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;\n    filter:\n      drop-shadow(0 1px 0 rgba(255,255,255,.6))\n      drop-shadow(0 0 6px color-mix(in srgb, var(--t) 70%, #fff))\n      drop-shadow(0 0 16px var(--tg))\n      drop-shadow(0 0 34px var(--tg));\n    animation: letterFloat 6.5s ease-in-out infinite, neonPulse 4.8s ease-in-out infinite;\n    will-change: transform, filter;\n  }\n  /* the neon-tube halo — a blurred coloured clone of the glyph sitting behind it */\n  .badge .letter::before {\n    content: attr(data-l); position: absolute; inset: 0; display: grid; place-items: center; z-index: -1;\n    -webkit-text-fill-color: var(--t); color: var(--t);\n    filter: blur(11px) saturate(150%);\n    opacity: calc(.85 * var(--glow-mult, 1));\n    animation: neonFlicker 7s steps(1, end) infinite;\n  }\n  /* tighter white inner clone — the bright core of the tube */\n  .badge .letter::after {\n    content: attr(data-l); position: absolute; inset: 0; display: grid; place-items: center; z-index: -1;\n    -webkit-text-fill-color: #fff; color: #fff;\n    filter: blur(2.5px);\n    opacity: calc(.5 * var(--glow-mult, 1));\n    animation: neonFlicker 7s steps(1, end) infinite .4s;\n  }\n  @keyframes letterFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }\n  @keyframes neonPulse {\n    0%, 100% { filter:\n      drop-shadow(0 1px 0 rgba(255,255,255,.6)) drop-shadow(0 0 6px color-mix(in srgb, var(--t) 70%, #fff))\n      drop-shadow(0 0 14px var(--tg)) drop-shadow(0 0 30px var(--tg)); }\n    50% { filter:\n      drop-shadow(0 1px 0 rgba(255,255,255,.7)) drop-shadow(0 0 9px color-mix(in srgb, var(--t) 82%, #fff))\n      drop-shadow(0 0 22px var(--tg)) drop-shadow(0 0 50px var(--tg)); }\n  }\n  /* neon-sign flicker — brief irregular dips, staggered per tier just below */\n  @keyframes neonFlicker {\n    0%, 7%, 9.2%, 13%, 52%, 54.5%, 83%, 100% { opacity: calc(.85 * var(--glow-mult, 1)); }\n    8%, 12% { opacity: calc(.34 * var(--glow-mult, 1)); }\n    53% { opacity: calc(.5 * var(--glow-mult, 1)); }\n    84%, 86% { opacity: calc(.52 * var(--glow-mult, 1)); }\n  }\n  .tier[data-tier=A] .letter::before, .tier[data-tier=A] .letter::after { animation-delay: -2.1s, -1.7s; }\n  .tier[data-tier=B] .letter::before, .tier[data-tier=B] .letter::after { animation-delay: -4.3s, -3.9s; }\n  .tier[data-tier=C] .letter::before, .tier[data-tier=C] .letter::after { animation-delay: -1.1s, -0.7s; }\n  .badge .cnt { position: relative; z-index: 1; font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-soft); font-weight: 700; }\n  .badge .cnt b { color: #fff; }\n  /* individual soft neon breathing per tier */\n  .badge { animation: neonBreathe 4.8s ease-in-out infinite; }\n  @keyframes neonBreathe {\n    0%, 100% { box-shadow: 0 18px 46px -22px rgba(0,0,0,.9), inset 0 1px 0 rgba(255,255,255,.10), inset 0 0 0 1px rgba(255,255,255,.04), 0 0 44px -22px var(--tg); }\n    50%      { box-shadow: 0 18px 46px -22px rgba(0,0,0,.9), inset 0 1px 0 rgba(255,255,255,.14), inset 0 0 0 1px rgba(255,255,255,.08), 0 0 76px -10px var(--tg); }\n  }\n  .tier[data-tier=S] .badge { animation-delay: 0s; }\n  .tier[data-tier=A] .badge { animation-delay: -1.2s; }\n  .tier[data-tier=B] .badge { animation-delay: -2.4s; }\n  .tier[data-tier=C] .badge { animation-delay: -3.6s; }\n\n  .panel {\n    position: relative; border-radius: var(--radius); padding: 18px 20px 22px;\n    background:\n      radial-gradient(80% 140% at 0% 0%, color-mix(in srgb, var(--t) 9%, transparent), transparent 46%),\n      linear-gradient(160deg, rgba(255,255,255,var(--surface-hi)), rgba(255,255,255,var(--surface-lo))),\n      var(--surface-fill);\n    border: 1px solid var(--glass-line);\n    backdrop-filter: blur(var(--panel-blur)) saturate(140%); -webkit-backdrop-filter: blur(var(--panel-blur)) saturate(140%);\n    box-shadow:\n      0 26px 64px -34px rgba(0,0,0,.92),\n      inset 0 1px 0 rgba(255,255,255,.06),\n      inset 1px 0 0 color-mix(in srgb, var(--t) 22%, transparent);\n    overflow: hidden;\n  }\n  .panel::before {\n    content: \"\"; position: absolute; left: 0; top: 0; right: 0; height: 2px;\n    background: linear-gradient(90deg, transparent, var(--t), var(--t2), transparent);\n    opacity: .7;\n  }\n  .panel-head {\n    display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap;\n    padding-bottom: 14px; margin-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,.08);\n  }\n  .panel-head .label { font-family: var(--serif); font-size: 19px; color: #fff; }\n  .panel-head .tagline { font-size: 12.5px; color: var(--ink-faint); flex: 1; min-width: 160px; }\n  .panel-head .pillct {\n    font-size: 11px; font-weight: 700; letter-spacing: .08em; color: var(--t2);\n    border: 1px solid color-mix(in srgb, var(--t) 40%, transparent); padding: 4px 10px; border-radius: 999px;\n    background: color-mix(in srgb, var(--t) 12%, transparent);\n  }\n\n  /* ── GRID (poster) view ── */\n  .items.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(118px, 1fr)); gap: 12px; }\n  .card {\n    position: relative; aspect-ratio: 2 / 3; border-radius: 15px; overflow: hidden; cursor: pointer;\n    background: linear-gradient(160deg, color-mix(in srgb, var(--t) 28%, #15101f), #100c1c);\n    border: 1px solid rgba(255,255,255,.09);\n    box-shadow: 0 10px 26px -16px rgba(0,0,0,.85), inset 0 0 0 1px rgba(255,255,255,.03);\n    transition: transform .3s cubic-bezier(.2,.8,.2,1), box-shadow .3s, border-color .3s;\n    will-change: transform;\n  }\n  .card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .5s ease; }\n  .card img.loaded { opacity: 1; }\n  .card .ph {\n    position: absolute; inset: 0; display: grid; place-items: center; padding: 8px; text-align: center;\n    font-family: var(--serif); font-size: 13px; color: rgba(255,255,255,.7);\n  }\n  .card .scrim {\n    position: absolute; inset: 0; z-index: 2;\n    background: linear-gradient(to top, rgba(5,3,12,.92) 6%, rgba(5,3,12,.35) 38%, transparent 60%);\n    opacity: .92; transition: opacity .3s;\n  }\n  .card .nm {\n    position: absolute; left: 0; right: 0; bottom: 0; z-index: 3; padding: 9px 10px;\n    font-size: 12px; font-weight: 700; line-height: 1.22; color: #fff; text-wrap: pretty;\n    text-shadow: 0 1px 4px rgba(0,0,0,.8);\n  }\n  .card .nm .watched {\n    display: block; margin-top: 4px; font-size: 9.5px; font-weight: 700; letter-spacing: .04em;\n    color: var(--t2); text-shadow: 0 1px 3px rgba(0,0,0,.9); opacity: .95;\n  }\n  .card .nm .watched i { font-style: normal; margin-left: 5px; padding: 1px 5px; border-radius: 6px; font-size: 8.5px; background: color-mix(in srgb, var(--t) 38%, transparent);