: flex; gap: 7px; }\n  .rxpick button { flex: 1; height: 46px; border-radius: 11px; cursor: pointer; display: grid; place-items: center;\n    background: rgba(255,255,255,.04); border: 1px solid var(--glass-line); transition: transform .16s, background .16s, border-color .16s, box-shadow .16s; }\n  .rxpick button svg { width: 22px; height: 22px; }\n  .rxpick button.none { color: var(--ink-faint); }\n  .rxpick button:hover { transform: translateY(-1px); background: rgba(255,255,255,.08); }\n  .rxpick button.sel { border-color: currentColor; background: color-mix(in srgb, currentColor 14%, transparent); box-shadow: 0 0 0 1px currentColor inset, 0 6px 18px -8px currentColor; }\n  .rxpick button.none.sel { color: var(--ink); }\n  .switch { display: flex; align-items: center; gap: 12px; cursor: pointer; user-select: none; }\n  .switch input { display: none; }\n  .switch .track { width: 44px; height: 25px; border-radius: 999px; background: rgba(255,255,255,.12); position: relative; transition: background .25s; flex: none; }\n  .switch .track::after { content: \"\"; position: absolute; top: 3px; left: 3px; width: 19px; height: 19px; border-radius: 50%; background: #fff; transition: transform .25s; }\n  .switch input:checked + .track { background: linear-gradient(150deg, var(--s2), var(--s)); }\n  .switch input:checked + .track::after { transform: translateX(19px); }\n  .switch .stxt { font-size: 13.5px; font-weight: 600; }\n  .modal-foot { display: flex; gap: 10px; justify-content: flex-end; padding: 14px 22px 22px; }\n\n  /* watched-date editor rows */\n  .wlist-edit { display: flex; flex-direction: column; gap: 8px; }\n  .wlist-edit:empty { display: none; }\n  .wrow { display: flex; gap: 8px; align-items: center; }\n  .wrow input { padding: 10px 12px; border-radius: 10px; color: var(--ink); font-family: var(--sans); font-size: 13.5px; background: rgba(255,255,255,.05); border: 1px solid var(--glass-line); outline: none; transition: border-color .2s, box-shadow .2s; min-width: 0; }\n  .wrow .wlabel { flex: 1 1 auto; }\n  .wrow .wdate { flex: 0 0 118px; text-align: center; letter-spacing: .04em; }\n  .wrow input:focus { border-color: var(--s); box-shadow: 0 0 0 3px rgba(255,92,149,.18); }\n  .wrow .wdel { flex: none; width: 34px; height: 34px; border-radius: 9px; cursor: pointer; display: grid; place-items: center; background: rgba(255,255,255,.04); border: 1px solid var(--glass-line); color: #ff8aa8; font-size: 13px; transition: all .18s; }\n  .wrow .wdel:hover { background: #ff5c95; color: #fff; border-color: transparent; }\n  .addwatch { margin-top: 10px; width: 100%; padding: 10px; border-radius: 10px; cursor: pointer; font-family: var(--sans); font-weight: 700; font-size: 12.5px; letter-spacing: .02em; color: var(--ink-soft); background: rgba(255,255,255,.035); border: 1.5px dashed var(--glass-line); transition: all .2s; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }\n  .addwatch:hover { color: #fff; border-color: rgba(255,255,255,.32); background: rgba(255,255,255,.07); }\n  .addwatch svg { width: 15px; height: 15px; }\n\n  /* ── search ── */\n  .search {\n    display: flex; align-items: center; gap: 8px; padding: 0 14px; height: 38px; flex-shrink: 1; min-width: 0;\n    border-radius: 999px; background: var(--glass); border: 1px solid var(--glass-line);\n    transition: border-color .2s, box-shadow .2s, background .2s;\n  }\n  .search:focus-within { border-color: color-mix(in srgb, var(--s) 60%, transparent); box-shadow: 0 0 0 3px rgba(255,92,149,.14); background: var(--glass-2); }\n  .search svg { width: 16px; height: 16px; color: var(--ink-faint); flex: none; }\n  .search input { border: 0; background: transparent; outline: none; color: var(--ink); font-family: var(--sans); font-size: 13px; width: 158px; min-width: 0; }\n  .search input::placeholder { color: var(--ink-faint); }\n\n  /* ── danger / confirm-delete ── */\n  .btn.danger { color: #ff9bb3; border-color: color-mix(in srgb, #ff3d6e 46%, transparent); background: color-mix(in srgb, #ff3d6e 9%, transparent); }\n  .btn.danger:hover { color: #fff; border-color: transparent; transform: translateY(-1px); background: linear-gradient(150deg, #ff7a9a, #ff3d6e); box-shadow: 0 12px 28px -8px rgba(255,61,110,.5); }\n  .confirm .modal { width: min(416px, 100%); }\n  .confirm-ico {\n    width: 56px; height: 56px; border-radius: 17px; display: grid; place-items: center; margin: 24px auto 0; color: #ff86a6;\n    background: radial-gradient(circle at 50% 38%, rgba(255,92,149,.24), rgba(255,92,149,.04));\n    border: 1px solid color-mix(in srgb, #ff5c95 38%, transparent); box-shadow: 0 0 40px -8px var(--s-g);\n  }\n  .confirm-ico svg { width: 26px; height: 26px; }\n  .confirm .modal-head { text-align: center; padding: 18px 28px 0; }\n  .confirm .modal-head h3 { font-family: var(--serif); font-size: 22px; font-weight: 400; }\n  .confirm .modal-head p { font-size: 13.5px; color: var(--ink-soft); margin-top: 10px; line-height: 1.55; }\n  .confirm .modal-head p b { color: #fff; font-weight: 700; }\n  .confirm .modal-foot { padding: 22px 28px 26px; }\n  .confirm .modal-foot .btn { flex: 1; justify-content: center; padding: 12px 0; font-size: 13.5px; }\n  .confirm .modal-foot .btn.primary:focus-visible { outline: none; box-shadow: 0 10px 26px -8px var(--s-g), 0 0 0 3px rgba(255,158,196,.55); }\n\n  /* ── taste statistics (bento) ── */\n  .statsmodal { width: min(560px, 100%); }\n  .stats-body { padding: 14px 22px 6px; }\n  .bento { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }\n  .bento-cell { border-radius: 16px; padding: 16px; background: linear-gradient(160deg, rgba(255,255,255,.055), rgba(255,255,255,.018)); border: 1px solid var(--glass-line); }\n  .donut-cell, .verdict-cell { grid-column: span 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; text-align: center; }\n  .donut { position: relative; width: 138px; height: 138px; border-radius: 50%; background: conic-gradient(rgba(255,255,255,.08) 0deg 360deg); }\n  .donut::after { content: \"\"; position: absolute; inset: 19px; border-radius: 50%; background: #16112a; box-shadow: inset 0 1px 0 rgba(255,255,255,.06); }\n  .donut-hole { position: absolute; inset: 0; display: grid; place-items: center; z-index: 1; line-height: 1; }\n  .donut-hole b { font-family: var(--serif); font-size: 30px; color: #fff; }\n  .donut-hole span { display: block; font-size: 9.5px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-faint); margin-top: 4px; }\n  .donut-legend { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px 12px; }\n  .donut-legend .lg { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; color: var(--ink-soft); }\n  .donut-legend .lg i { width: 10px; height: 10px; border-radius: 3px; }\n  .verdict-emoji { font-size: 42px; line-height: 1; filter: drop-shadow(0 4px 12px rgba(0,0,0,.5)); animation: badgeBloom 5s ease-in-out infinite alternate; }\n  .verdict-title { font-family: var(--serif); font-size: 21px; color: #fff; }\n  .verdict-desc { font-size: 12.5px; color: var(--ink-soft); line-height: 1.5; }\n  .stat-cell { display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 3px; }\n  .stat-cell b { font-family: var(--serif); font-size: 26px; color: #fff; line-height: 1; }\n  .stat-cell span { font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-faint); }\n  @media (max-width: 520px) { .bento { grid-template-columns: 1fr; } }\n\n  /* toast */\n  .toast {\n    position: fixed; left: 50%; bottom: 30px; transform: translate(-50%, 20px); z-index: 300;\n    padding: 12px 20px; border-radius: 999px; font-size: 13px; font-weight: 700; color: #fff;\n    background: rgba(18,14,32,.94); border: 1px solid var(--glass-line); box-shadow: 0 18px 50px -16px rgba(0,0,0,.8);\n    opacity: 0; pointer-events: none; transition: opacity .3s, transform .3s; display: inline-flex; align-items: center; gap: 9px;\n  }\n  .toast.show { opacity: 1; transform: translate(-50%, 0); }\n  .toast .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--a); box-shadow: 0 0 10px var(--a); }\n\n  footer.foot {\n    margin-top: 56px; padding-top: 4px;\n    display: flex; flex-direction: column; align-items: center; gap: 16px; text-align: center;\n  }\n  /* ornamental gradient divider with a slowly turning sakura at its centre */\n  .foot-divider {\n    position: relative; width: min(560px, 92%); height: 1px;\n    background: linear-gradient(90deg, transparent, var(--rule) 18%, rgba(255,255,255,.22) 50%, var(--rule) 82%, transparent);\n  }\n  .foot-orn {\n    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);\n    font-size: 17px; line-height: 1; color: var(--s2); background: var(--bg-0); padding: 0 13px;\n    text-shadow: 0 0 12px var(--s-g); animation: footOrn 9s ease-in-out infinite;\n  }\n  @keyframes footOrn { 0%,100% { transform: translate(-50%,-50%) rotate(0) scale(1); } 50% { transform: translate(-50%,-50%) rotate(180deg) scale(1.14); } }\n  /* signature with a flowing tier-spectrum gradient (S gold → B → A → C) */\n  .foot .sig {\n    font-family: var(--serif); font-size: clamp(16px, 2.4vw, 21px); letter-spacing: .01em; line-height: 1.2;\n    background: linear-gradient(110deg, var(--gold) 0%, var(--b) 30%, var(--a) 54%, var(--c) 76%, var(--gold) 100%);\n    background-size: 220% 100%;\n    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;\n    animation: footSig 12s ease-in-out infinite;\n  }\n  @keyframes footSig { 0%,100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }\n  /* four glowing tier dots */\n  .foot-dots { display: inline-flex; gap: 13px; }\n  .foot-dot { width: 9px; height: 9px; border-radius: 50%; animation: footDot 3.4s ease-in-out infinite; }\n  .foot-dot.d-s { background: var(--gold); box-shadow: 0 0 11px var(--gold-g); }\n  .foot-dot.d-a { background: var(--a);    box-shadow: 0 0 11px var(--a-g); animation-delay: -.85s; }\n  .foot-dot.d-b { background: var(--b);    box-shadow: 0 0 11px var(--b-g); animation-delay: -1.7s; }\n  .foot-dot.d-c { background: var(--c);    box-shadow: 0 0 11px var(--c-g); animation-delay: -2.55s; }\n  @keyframes footDot { 0%,100% { opacity: .5; transform: scale(.82); } 50% { opacity: 1; transform: scale(1.18); } }\n  .foot-meta { display: inline-flex; align-items: center; gap: 11px; font-size: 10.5px; letter-spacing: .22em; text-transform: uppercase; color: var(--ink-faint); }\n  .foot-meta .foot-sep { opacity: .45; }\n\n  /* tier color binding (S is elevated to gold + crimson — see elite block below) */\n  .tier[data-tier=S] { --t: var(--gold); --t2: var(--crimson); --tg: var(--gold-g); }\n  .tier[data-tier=A] { --t: var(--a); --t2: var(--a2); --tg: var(--a-g); }\n  .tier[data-tier=B] { --t: var(--b); --t2: var(--b2); --tg: var(--b-g); }\n  .tier[data-tier=C] { --t: var(--c); --t2: var(--c2); --tg: var(--c-g); }\n  .preview[data-tier=S] { --t: var(--gold); --t2: var(--crimson); --tg: var(--gold-g); }\n  .preview[data-tier=A] { --t: var(--a); --t2: var(--a2); --tg: var(--a-g); }\n  .preview[data-tier=B] { --t: var(--b); --t2: var(--b2); --tg: var(--b-g); }\n  .preview[data-tier=C] { --t: var(--c); --t2: var(--c2); --tg: var(--c-g); }\n\n  /* ═══════════ S-TIER ELITE: gilded badge + crown + crimson inner glow ═══════════ */\n  .tier[data-tier=S] .badge {\n    box-shadow:\n      0 20px 48px -22px rgba(0,0,0,.92),\n      inset 0 1px 0 rgba(255,255,255,.18),\n      inset 0 0 0 1px rgba(255,216,140,.28),\n      inset 0 0 26px -6px var(--crimson-g),\n      0 0 64px -16px var(--gold-g);\n  }\n  /* second, brighter gilded ring drawn over the standard gradient frame */\n  .tier[data-tier=S] .badge::before {\n    background: linear-gradient(150deg, var(--gold2), var(--gold) 38%, var(--crimson) 78%, transparent 92%);\n    opacity: 1;\n  }\n  .tier[data-tier=S] .badge .cnt b { color: var(--gold2); }\n  .tier[data-tier=S] .pillct { text-shadow: 0 0 10px var(--gold-g); }\n  /* crown sits above the letter — visible only on S */\n  .crown {\n    display: none; position: absolute; top: -14px; left: 50%; z-index: 3;\n    width: 34px; height: 24px; color: var(--gold);\n    filter: drop-shadow(0 0 7px var(--gold-g)) drop-shadow(0 1px 0 rgba(168,18,63,.5));\n    animation: crownFloat 4.2s ease-in-out infinite;\n  }\n  .crown svg { width: 100%; height: 100%; display: block; }\n  .tier[data-tier=S] .crown { display: block; }\n  @keyframes crownFloat {\n    0%, 100% { transform: translateX(-50%) translateY(0) rotate(-2deg); }\n    50%      { transform: translateX(-50%) translateY(-3px) rotate(2deg); }\n  }\n\n  /* ═══════════ PER-TIER CARD HOVER PERSONALITIES ═══════════\n     Only glow / border / sheen / runner is customised here — the lift transform\n     is left to .card:hover (or .fx-tilt's 3D tilt) so tilt keeps working. */\n  /* S — royal: gold+crimson double bloom, gilded inner ring + gold running border */\n  body:not(.editing) .tier[data-tier=S] .card:hover {\n    border-color: color-mix(in srgb, var(--gold) 78%, transparent);\n    box-shadow: 0 30px 58px -16px rgba(0,0,0,.86), 0 0 56px -10px var(--gold-g), 0 0 28px -8px var(--crimson-g), inset 0 0 0 1.5px rgba(255,226,150,.55);\n  }\n  .tier[data-tier=S] .card::before { background: linear-gradient(115deg, transparent 30%, rgba(255,226,150,.42) 46%, rgba(255,255,255,.5) 51%, rgba(224,53,107,.22) 60%, transparent 74%); }\n  body:not(.editing) .tier[data-tier=S] .card:hover::after {\n    content: \"\"; position: absolute; inset: 0; border-radius: inherit; z-index: 6; padding: 1.5px; pointer-events: none;\n    background: conic-gradient(from var(--ang), transparent 0deg, var(--gold2) 22deg, var(--gold) 44deg, var(--crimson) 72deg, transparent 122deg, transparent 360deg);\n    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);\n    -webkit-mask-composite: xor; mask-composite: exclude;\n    opacity: calc(.85 * var(--glow-mult, 1)); animation: neonRun 4.5s linear infinite;\n  }\n\n  /* A — holographic: crisp cyan edge + prismatic scan-line sheen */\n  body:not(.editing) .tier[data-tier=A] .card:hover {\n    box-shadow: 0 24px 48px -16px rgba(0,0,0,.82), 0 0 44px -12px var(--a-g), inset 0 0 0 1px rgba(120,210,255,.5), inset 0 0 18px -6px rgba(105,176,255,.5);\n  }\n  .tier[data-tier=A] .card::before { background: linear-gradient(100deg, transparent 38%, rgba(120,225,255,.34) 48%, rgba(190,245,255,.55) 50%, rgba(105,176,255,.24) 54%, transparent 64%); }\n\n  /* B — arcane: pulsing violet aura */\n  body:not(.editing) .tier[data-tier=B] .card:hover {\n    border-color: color-mix(in srgb, var(--b) 60%, transparent);\n    animation: bArcane 1.7s ease-in-out infinite;\n  }\n  @keyframes bArcane {\n    0%, 100% { box-shadow: 0 24px 48px -16px rgba(0,0,0,.82), 0 0 40px -12px var(--b-g); }\n    50%      { box-shadow: 0 24px 48px -16px rgba(0,0,0,.82), 0 0 66px -6px var(--b-g), inset 0 0 0 1px rgba(209,155,255,.55); }\n  }\n  .tier[data-tier=B] .card::before { background: linear-gradient(125deg, transparent 32%, rgba(209,155,255,.32) 47%, rgba(255,255,255,.36) 54%, transparent 72%); }\n\n  /* C — verdant: fresh emerald glow that breathes */\n  body:not(.editing) .tier[data-tier=C] .card:hover {\n    border-color: color-mix(in srgb, var(--c) 60%, transparent);\n    animation: cVerdant 1.9s ease-in-out infinite;\n  }\n  @keyframes cVerdant {\n    0%, 100% { box-shadow: 0 24px 48px -16px rgba(0,0,0,.82), 0 0 38px -12px var(--c-g); }\n    50%      { box-shadow: 0 24px 48px -16px rgba(0,0,0,.82), 0 0 62px -8px var(--c-g), 0 0 24px -6px rgba(61,220,132,.55); }\n  }\n  .tier[data-tier=C] .card::before { background: linear-gradient(110deg, transparent 34%, rgba(255,200,120,.34) 48%, rgba(255,240,200,.48) 52%, transparent 70%); }\n\n  /* ═══════════ ENHANCED NEON EFFECTS (toggleable) ═══════════ */\n  @property --ang { syntax: '<angle>'; inherits: false; initial-value: 0deg; }\n\n  /* flowing light that travels along the panel border (lit under .fx-neon) */\n  .fx-neon .panel::after {\n    content: \"\"; position: absolute; inset: 0; border-radius: inherit; z-index: 6;\n    padding: 1.5px; pointer-events: none;\n    background: conic-gradient(from var(--ang),\n      transparent 0deg,\n      color-mix(in srgb, var(--t) 80%, #fff) 28deg,\n      var(--t2) 56deg,\n      transparent 116deg, transparent 360deg);\n    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);\n    -webkit-mask-composite: xor; mask-composite: exclude;\n    opacity: calc(.5 * var(--glow-mult, 1));\n    animation: neonRun 8s linear infinite;\n  }\n  /* the badge outline runner — a neon tube that always traces the S/A/B/C frame,\n     faint by default and brightened when \"живой неон\" (fx-neon) is on */\n  .brun {\n    position: absolute; inset: 0; border-radius: inherit; z-index: 6; pointer-events: none;\n    padding: 1.4px;\n    background: conic-gradient(from var(--ang),\n      transparent 0deg,\n      color-mix(in srgb, var(--t) 80%, #fff) 26deg,\n      var(--t2) 54deg,\n      transparent 112deg, transparent 360deg);\n    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);\n    -webkit-mask-composite: xor; mask-composite: exclude;\n    opacity: calc(.3 * var(--glow-mult, 1));\n    animation: neonRun 7s linear infinite;\n  }\n  .fx-neon .brun { opacity: calc(.62 * var(--glow-mult, 1)); animation-duration: 6s; }\n  .tier[data-tier=A] .brun { animation-delay: -1.6s; }\n  .tier[data-tier=B] .brun { animation-delay: -3.2s; }\n  .tier[data-tier=C] .brun { animation-delay: -4.8s; }\n  @keyframes neonRun { to { --ang: 360deg; } }\n\n  /* badges respond to hover: a gentle magnetic lift, with optional 3D tilt */\n  .badge { transition: transform .42s cubic-bezier(.2,.8,.2,1); }\n  .tier:hover .badge { transform: translateY(-3px) scale(1.015); }\n  .fx-tilt .badge { transition: transform .18s cubic-bezier(.2,.8,.2,1); transform-style: preserve-3d; }\n  .fx-tilt .tier:hover .badge {\n    transform: perspective(720px) rotateY(var(--brx, 0deg)) rotateX(var(--bry, 0deg)) translateY(-3px);\n  }\n\n  /* moving light sweep + zoom on poster hover */\n  .card::before {\n    content: \"\"; position: absolute; inset: 0; z-index: 4; pointer-events: none; opacity: 0;\n    background: linear-gradient(115deg, transparent 32%, rgba(255,255,255,.16) 47%, rgba(255,255,255,.04) 56%, transparent 72%);\n    transform: translateX(-120%);\n  }\n  .card:hover::before { opacity: 1; animation: sheen 1.05s cubic-bezier(.3,.6,.3,1) .04s 1 forwards; }\n  @keyframes sheen { to { transform: translateX(120%); } }\n  .card img { transition: opacity .5s ease, transform .55s cubic-bezier(.2,.8,.2,1); }\n  .card:hover img { transform: scale(1.07); }\n  /* running border light on poster hover (kept light — hover only) */\n  .fx-neon .card:hover::after {\n    content: \"\"; position: absolute; inset: 0; border-radius: inherit; z-index: 6; padding: 1.4px; pointer-events: none;\n    background: conic-gradient(from var(--ang), transparent 0deg, color-mix(in srgb, var(--t) 80%, #fff) 26deg, var(--t2) 52deg, transparent 110deg, transparent 360deg);\n    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);\n    -webkit-mask-composite: xor; mask-composite: exclude;\n    opacity: calc(.7 * var(--glow-mult, 1)); animation: neonRun 5s linear infinite;\n  }\n\n  /* 3D tilt toward cursor */\n  .fx-tilt .card { transition: transform .16s cubic-bezier(.2,.8,.2,1), box-shadow .3s, border-color .3s; transform-style: preserve-3d; }\n  .fx-tilt .card:hover {\n    transform: perspective(720px) rotateY(var(--rx, 0deg)) rotateX(var(--ry, 0deg)) translateY(-8px) scale(1.04);\n  }\n\n  /* neon hearts */\n  @keyframes heartPulse { 0%,100% { transform: scale(1); opacity: .92; } 50% { transform: scale(1.16); opacity: 1; } }\n  @keyframes heartRipple { 0% { opacity: .8; transform: translate(-50%,-50%) scale(.4); } 100% { opacity: 0; transform: translate(-50%,-50%) scale(4); } }\n  .card .rx::after, .chip .rx::after {\n    content: \"\"; position: absolute; left: 50%; top: 50%; width: 7px; height: 7px; border-radius: 50%;\n    border: 2px solid currentColor; opacity: 0; pointer-events: none;\n    transform: translate(-50%,-50%) scale(.4);\n  }\n  .card:hover .rx::after, .chip:hover .rx::after { animation: heartRipple .95s ease-out 1; }\n\n  /* animated title glow */\n  .masthead h1 { position: relative; }\n  /* slow cinematic light-ray sweep behind the title */\n  .masthead h1::before {\n    content: \"\"; position: absolute; left: 50%; top: 50%; width: 150%; aspect-ratio: 1; z-index: -2;\n    transform: translate(-50%, -50%); pointer-events: none; border-radius: 50%;\n    opacity: calc(.30 * var(--glow-mult, 1)); filter: blur(7px);\n    background: conic-gradient(from 0deg,\n      transparent 0deg, var(--s-g) 16deg, transparent 40deg,\n      transparent 80deg, var(--a-g) 100deg, transparent 128deg,\n      transparent 188deg, var(--b-g, var(--s-g)) 208deg, transparent 236deg,\n      transparent 300deg, var(--a-g) 320deg, transparent 348deg);\n    -webkit-mask: radial-gradient(closest-side, transparent 24%, #000 42%, transparent 76%);\n    mask: radial-gradient(closest-side, transparent 24%, #000 42%, transparent 76%);\n    animation: titleRays 26s linear infinite;\n  }\n  @keyframes titleRays { to { transform: translate(-50%, -50%) rotate(360deg); } }\n  .masthead h1::after {\n    content: \"\"; position: absolute; inset: -14% -8%; z-index: -1; pointer-events: none;\n    filter: blur(40px); opacity: calc(.42 * var(--glow-mult, 1));\n    background: radial-gradient(58% 120% at 30% 50%, var(--s-g), transparent 70%), radial-gradient(58% 120% at 72% 50%, var(--a-g), transparent 72%);\n    animation: titleHalo 9s ease-in-out infinite alternate;\n  }\n  @keyframes titleHalo { 0% { opacity: calc(.3 * var(--glow-mult,1)); transform: scale(.97); } 100% { opacity: calc(.55 * var(--glow-mult,1)); transform: scale(1.04); } }\n  @keyframes titleFlow { 0%,100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }\n\n  /* cursor radial glow */\n  #cursorGlow {\n    position: fixed; z-index: 4; width: 480px; height: 480px; left: 0; top: 0; margin: -240px 0 0 -240px;\n    border-radius: 50%; pointer-events: none; opacity: 0; transition: opacity .45s; mix-blend-mode: screen;\n    background: radial-gradient(circle, rgba(255,165,205,.11), rgba(120,165,255,.05) 42%, transparent 70%);\n  }\n  .fx-cursor #cursorGlow { opacity: calc(.9 * var(--glow-mult, 1)); }\n\n  /* ── anime wings that flare beside a card on hover, then fade (~2.2s) ── */\n  #wings { position: fixed; z-index: 55; pointer-events: none; opacity: 0; transform: translate(-50%, -50%); will-change: opacity; }\n  #wings[data-tier=S] { color: var(--gold); }\n  #wings[data-tier=A] { color: var(--a); }\n  #wings[data-tier=B] { color: var(--b); }\n  #wings[data-tier=C] { color: var(--c); }\n  #wings .wing { position: absolute; top: 50%; }\n  #wings .wing svg { display: block; width: clamp(70px, 7vw, 104px); height: auto; filter: drop-shadow(0 0 9px currentColor) drop-shadow(0 0 20px currentColor); }\n  #wings .wing-l { right: 100%; margin-right: -8px; transform: translate(10px, -50%) rotate(8deg) scale(.7); }\n  #wings .wing-r { left: 100%;  margin-left: -8px;  transform: translate(-10px, -50%) scaleX(-1) rotate(8deg) scale(.7); }\n  #wings.show { animation: wingsFade 2.2s ease-out forwards; }\n  #wings.show .wing-l { animation: wingL 2.2s cubic-bezier(.2,.85,.25,1) forwards; }\n  #wings.show .wing-r { animation: wingR 2.2s cubic-bezier(.2,.85,.25,1) forwards; }\n  @keyframes wingsFade { 0% { opacity: 0; } 14% { opacity: 1; } 62% { opacity: .92; } 100% { opacity: 0; } }\n  @keyframes wingL {\n    0%   { transform: translate(16px, -50%) rotate(12deg) scale(.62); }\n    22%  { transform: translate(0, -50%) rotate(-3deg) scale(1.02); }\n    100% { transform: translate(-6px, -54%) rotate(-7deg) scale(1.06); }\n  }\n  @keyframes wingR {\n    0%   { transform: translate(-16px, -50%) scaleX(-1) rotate(12deg) scale(.62); }\n    22%  { transform: translate(0, -50%) scaleX(-1) rotate(-3deg) scale(1.02); }\n    100% { transform: translate(6px, -54%) scaleX(-1) rotate(-7deg) scale(1.06); }\n  }\n  @media (prefers-reduced-motion: reduce) { #wings { display: none; } }\n\n  /* tweaks panel */\n  .fx-gear {\n    position: fixed; right: 18px; bottom: 18px; z-index: 210; width: 46px; height: 46px; border-radius: 50%;\n    display: grid; place-items: center; cursor: pointer; color: var(--ink);\n    background: rgba(18,14,32,.86); border: 1px solid var(--glass-line);\n    backdrop-filter: blur(14px); box-shadow: 0 12px 34px -12px rgba(0,0,0,.8), 0 0 26px -10px var(--s-g);\n    transition: transform .3s, box-shadow .3s;\n  }\n  .fx-gear:hover { transform: rotate(40deg) scale(1.06); box-shadow: 0 12px 34px -12px rgba(0,0,0,.8), 0 0 32px -6px var(--s-g); }\n  .fx-gear svg { width: 22px; height: 22px; }\n  .fx-panel {\n    position: fixed; right: 18px; bottom: 74px; z-index: 210; width: 280px; padding: 16px 16px 18px;\n    border-radius: 18px; background: linear-gradient(165deg, rgba(24,18,40,.97), rgba(14,11,26,.98));\n    border: 1px solid var(--glass-line); box-shadow: 0 30px 80px -24px rgba(0,0,0,.9), 0 0 50px -18px var(--s-g);\n    backdrop-filter: blur(20px); transform: translateY(14px) scale(.97); opacity: 0; pointer-events: none;\n    transition: transform .3s cubic-bezier(.2,.8,.2,1), opacity .3s;\n  }\n  .fx-panel.show { transform: none; opacity: 1; pointer-events: auto; }\n  .fx-panel h4 { font-family: var(--serif); font-weight: 400; font-size: 17px; color: #fff; display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }\n  .fx-panel h4 button { background: none; border: 0; color: var(--ink-faint); cursor: pointer; font-size: 16px; padding: 4px; line-height: 1; }\n  .fx-panel h4 button:hover { color: #fff; }\n  .fx-panel .sub { font-size: 11px; color: var(--ink-faint); margin-bottom: 12px; }\n  .fx-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 9px 0; border-top: 1px solid rgba(255,255,255,.07); }\n  .fx-row span { font-size: 13px; color: var(--ink-soft); }\n  .fx-sw { position: relative; width: 40px; height: 23px; border-radius: 999px; background: rgba(255,255,255,.12); border: 1px solid var(--glass-line); cursor: pointer; flex: none; transition: background .25s; }\n  .fx-sw::after { content: \"\"; position: absolute; top: 2px; left: 2px; width: 17px; height: 17px; border-radius: 50%; background: #fff; transition: transform .25s cubic-bezier(.2,.8,.2,1); box-shadow: 0 2px 5px rgba(0,0,0,.4); }\n  .fx-sw.on { background: linear-gradient(120deg, var(--s2), var(--s)); border-color: transparent; }\n  .fx-sw.on::after { transform: translateX(17px); }\n  .fx-slider { display: flex; flex-direction: column; gap: 8px; padding: 12px 0 2px; border-top: 1px solid rgba(255,255,255,.07); }\n  .fx-slider span { font-size: 13px; color: var(--ink-soft); }\n  .fx-slider input { width: 100%; accent-color: var(--s); }\n\n  /* expressive \"feel\" controls */\n  .fx-panel { max-height: calc(100vh - 100px); overflow-y: auto; }\n  .fx-group { padding: 13px 0 5px; border-top: 1px solid rgba(255,255,255,.07); }\n  .fx-group > .fx-lbl { display: block; font-size: 12px; font-weight: 600; color: var(--ink-soft); margin-bottom: 9px; }\n  .fx-seg { display: grid; gap: 6px; }\n  .fx-seg.cols-2 { grid-template-columns: repeat(2, 1fr); }\n  .fx-seg.cols-3 { grid-template-columns: repeat(3, 1fr); }\n  .fx-seg button {\n    display: inline-flex; align-items: center; justify-content: center; gap: 7px;\n    padding: 8px 6px; border-radius: 10px; cursor: pointer;\n    font-family: var(--sans); font-weight: 700; font-size: 11px; letter-spacing: .01em;\n    color: var(--ink-faint); background: rgba(255,255,255,.035); border: 1px solid var(--glass-line);\n    transition: color .2s, background .2s, border-color .2s, box-shadow .2s;\n  }\n  .fx-seg button .dot { width: 11px; height: 11px; border-radius: 50%; flex: none; }\n  .fx-seg button:hover { color: var(--ink); border-color: rgba(255,255,255,.2); }\n  .fx-seg button.on { color: #fff; background: linear-gradient(150deg, rgba(255,255,255,.16), rgba(255,255,255,.05)); border-color: rgba(255,255,255,.3); box-shadow: inset 0 1px 0 rgba(255,255,255,.2); }\n  .dot-midnight { background: linear-gradient(135deg, #35e0d6, #a779ff); }\n  .dot-ember    { background: linear-gradient(135deg, #ff5c95, #ffc24d); }\n  .dot-abyss    { background: linear-gradient(135deg, #35e0d6, #69b0ff); }\n  .dot-sakura   { background: linear-gradient(135deg, #a779ff, #ff9ec4); }\n  .dot-shibuya  { background: linear-gradient(135deg, #69b0ff, #50c8dc); }\n\n  /* export mode */\n  body.exporting .toolbar, body.exporting .item-del, body.exporting .additem,\n  body.exporting .vignette, body.exporting #fxGear, body.exporting #fxPanel, body.exporting #cursorGlow, body.exporting #wings, body.exporting .rain-glass { visibility: hidden !important; }\n  #capture.exporting { background: radial-gradient(120% 90% at 50% 0%, #1a1330, #08060f 70%); padding: 40px; border-radius: 0; }\n\n  /* responsive */\n  @media (max-width: 720px) {\n    .tier { grid-template-columns: 84px 1fr; gap: 12px; }\n    .badge { padding: 12px 6px; }\n    .badge .letter { font-size: 42px; }\n    .items.grid { grid-template-columns: repeat(auto-fill, minmax(96px,1fr)); gap: 9px; }\n    .toolbar { gap: 10px; flex-wrap: wrap; }\n    .brand .txt span { display: none; }\n    .seg button .seg-lbl { display: none; }\n  }\n  @media (prefers-reduced-motion: reduce) {\n    *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }\n    .tier { opacity: 1 !important; transform: none !important; }\n  }\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n\n<d